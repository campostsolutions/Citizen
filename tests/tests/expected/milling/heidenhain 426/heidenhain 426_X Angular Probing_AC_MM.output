BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-11 Y-11 Z-40
BLK FORM 0.2 X+491 Y+491 Z+51
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;Machine
;  description: AC_table_table
;T1 D=+5 CR=+2.5 - ZMIN=-5 - probe
;T2 D=+10 CR=+0 - ZMIN=-19.9 - flat end mill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
* - X-angle
TOOL CALL 1 Z
TOOL DEF 2
L M140 MB MAX
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L A+0 C+0 R0 FMAX M94
CYCL DEF 19.0 WORKING PLANE
CYCL DEF 19.1 A+0 C+0 F9999
L A+Q120 C+Q122 R0 FMAX
L X-14.5 Y+40 R0 FMAX
L Z+66 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 403 ROT IN ROTARY AXIS ~
  Q263=+0 ;1ST POINT 1ST AXIS ~
  Q264=+50 ;1ST POINT 2ND AXIS ~
  Q265=+0 ;2ND POINT 1ST AXIS ~
  Q266=+30 ;2ND POINT 2ND AXIS ~
  Q272=+1 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+12 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q312=+6 ;COMPENSATION AXIS ~
  Q337=+1 ;SET TO ZERO ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q380=+0 ;REFERENCE ANGLE
L Z+66 FMAX
CALL LBL 1 ;DATUM
L M140 MB MAX
* - 2D Contour1 (2)
M5
M1
TOOL CALL 2 Z S5000
TOOL DEF 1
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L A+0 C+0 R0 FMAX M94
CYCL DEF 19.0 WORKING PLANE
CYCL DEF 19.1 A+0 C+0 F9999
L A+Q120 C+Q122 R0 FMAX
L X+81 Y-8.1 R0 FMAX
L Z+66 R0 FMAX
M8
L Z+56 FMAX
L Z+52 F333
L Z-18.9
CC Y-7.1 Z-18.9
CP IPA+90 DR+ F1000
L Y-6.1 Z-19.9
CC X+80 Y-6.1
CP IPA+90 DR+
L X+0 Y-5.1
CC X+0 Y-6.1
CP IPA+90 DR+
L X-1 Y-7.1
CC Y-7.1 Z-18.9
CP IPA-90 DR-
L Y-8.1 Z+66 FMAX
M9
M5
L M140 MB MAX
M127
M30
END PGM 1234 MM
