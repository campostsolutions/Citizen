BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-2.0085 Y-1.0243 Z-2.0085
BLK FORM 0.2 X+2.0085 Y+1.0243 Z+0
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;T1 D=+2 CR=+0 - ZMIN=-0.04 - face mill
;T2 D=+0.375 CR=+0 - ZMIN=-0.4337 - flat end mill
;T3 D=+0.2012 CR=+0 TAPER=118deg - ZMIN=-0.691 - drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
* - 2D-Face (7)
TOOL CALL 1 Z S5000
;myToolComment
TOOL DEF 2
L M140 MB MAX
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X+3.1896 Y-0.975 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CALL LBL 100
L M140 MB MAX
* - 2D-Face (7)
LBL 2
CYCL DEF 247 DATUM SETTING ~
  Q339=2 ; DATUM NUMBER
LBL 0
L X+3.1896 Y-0.975 R0 FMAX
L Z+0.5906 R0 FMAX
CALL LBL 100
M9
L M140 MB MAX
* - 2D-Contour with compensation left (5)
M5
M1
TOOL CALL 2 Z S5000
TOOL DEF 3
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-0.1377 Y+1.1944 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CALL LBL 101
L M140 MB MAX
* - 2D-Contour with compensation left (5)
CALL LBL 2 ;DATUM
L X-0.1377 Y+1.1944 R0 FMAX
L Z+0.5906 R0 FMAX
CALL LBL 101
M9
L M140 MB MAX
* - Rapid out (7)
M5
M1
TOOL CALL 3 Z S5000
TOOL DEF 1
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CALL LBL 102
L M140 MB MAX
* - Rapid out (7)
CALL LBL 2 ;DATUM
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.5906 R0 FMAX
CALL LBL 102
M9
M5
L M140 MB MAX
M30

LBL 100 ;2D-Face (7)
L Z+0.1969 FMAX
L Z-0.04 F196.85
L X-3.1896 F393.7
CC X-3.1896 Y-0.4563
CP IPA-180 DR-
L X+3.1896 Y+0.0624
L Z+0.5906 FMAX
LBL 0

LBL 101 ;2D-Contour with compensation left (5)
L Z+0.1969 FMAX
L Z+0.0394 F196.85
L Z-0.4337
L X-0.344 Y+1.1905 RL F393.7
CC X-0.0196 Y+1.1905
CP IPA+90 DR+
L X+1.5354 Y+0.8661
CC X+1.5354 Y+0.5512
CP IPA-90 DR-
L X+1.8504 Y-0.8661
L X-1.6535
CC X-1.6535 Y-0.6693
CP IPA-90 DR-
L X-1.8504 Y+0.8661
L X-0.0196
CC X-0.0196 Y+1.1905
CP IPA+90 DR+
L X+0.0985 Y+1.1944 R0
L Z+0.5906 FMAX
LBL 0

LBL 102 ;Rapid out (7)
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.651 ;DEPTH ~
  Q206=157.48 ;FEED RATE FOR PLUNGING ~
  Q202=+0.651 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.04 ;SURFACE COORDINATE ~
  Q204=+0.2369 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+0.9843 FMAX M99
L Z+0.5906 FMAX
LBL 0

END PGM 1234 INCH
