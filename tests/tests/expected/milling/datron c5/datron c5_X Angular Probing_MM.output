!Makro file ; V9.85D!
!mycomment!

!Please make sure that the language on your control is set to "en"!
_sprache 1;

Dimension 1;

Variable optional_stop, $Message, T1, T2, startOperation, Op_X_angle, Op_2dcontour12, Finish, Entry, Exit, Plunge, Xvalue1, Xvalue2, Yvalue1, Yvalue2, Zvalue, Newpos, Rotationvalue;

Smakros Sm_X_angle, Sm_2dcontour12;

_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <X_angle<1>, 2dcontour12<2>>", "Select the operation to start with. ";

(
ToolRetraction;
Shift 1, 0, 0, 0;
Tilt 1, 0, 0, 0, 0, 10;
Axyz 1, -14.5, 40, z6p, 0, 0;
Axyz 1, -14.5, 40, 66, 0, 0;
Axyz 1, -14.5, 40, 66, 0, 0;
Feed 1, 1, 1, 1;
Axyz 1, -14.5, 40, 56, 0, 0;
Axyz 1, -14.5, 50, 56, 0, 0;
Axyz 0, -14.5, 50, -5, 0, 0;
Xvalue1 = 5;
Xvalue2 = 5;
Taxyz 2, Xvalue1, Y6p, Z6p, 1, 0, 0;
Axyz 1, x6p, y6p, 56, 0, 0;
Axyz 1, -14.5, 30, 56, 0, 0;
Axyz 0, -14.5, 30, -5, 0, 0;
Taxyz 2, Xvalue2, Y6p, Z6p, 1, 0, 0;
Rotationvalue = Arctan ( ( Xvalue2 - Xvalue1 ) / (50-30) );
Rotation Rotationvalue, 1, 1, 1, 0, 0;
Axyz 1, X6p, Y6p, 56, 0, 0;
Axyz 1, -14.5, 40, 56, 0, 0;
Position 1, 3;
Axyz 1, -14.5, 40, 66, 0, 0;
Rpm 1, 30, 0, 30;
ToolRetraction;
Tilt 0, 0, 0, 0, 2, 10;
Shift 0, 0, 0, 0;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
Message $Message, 0, 0, 0;
$Message = "OK";
) Sm_x_angle;
(
ToolRetraction;
Shift 1, 0, 0, 0;
Tilt 1, 0, 0, 0, 0, 10;
Contour_smoothing 1, 0.012, 0.1, 110, 1;
Axyz 1, 81, -8.1, z6p, 0, 0;
Axyz 1, 81, -8.1, 66, 0, 0;
Axyz 1, 81, -8.1, 66, 0, 0;
Axyz 1, 81, -8.1, 56, 0, 0;
Feed Plunge, Plunge, Plunge, Plunge;
Axyz 0, 81, -8.1, 52, 0, 0;
Axyz 0, 81, -8.1, -18.9, 0, 0;
Feed Entry, Entry, Entry, Entry;
Axyz 0, 81, -8.09271, -19.02054, 0, 0;
Axyz 0, 81, -8.07094, -19.13932, 0, 0;
Axyz 0, 81, -8.03502, -19.25461, 0, 0;
Axyz 0, 81, -7.98546, -19.36472, 0, 0;
Axyz 0, 81, -7.92298, -19.46807, 0, 0;
Axyz 0, 81, -7.84851, -19.56312, 0, 0;
Axyz 0, 81, -7.76312, -19.64851, 0, 0;
Axyz 0, 81, -7.66806, -19.72298, 0, 0;
Axyz 0, 81, -7.56472, -19.78546, 0, 0;
Axyz 0, 81, -7.4546, -19.83502, 0, 0;
Axyz 0, 81, -7.33932, -19.87094, 0, 0;
Axyz 0, 81, -7.22054, -19.89271, 0, 0;
Axyz 0, 81, -7.1, -19.9, 0, 0;
Axyz 0, 81, -6.1, -19.9, 0, 0;
Circle 2, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Feed Finish, Finish, Finish, Finish;
Axyz 0, 0, -5.1, -19.9, 0, 0;
Feed Exit, Exit, Exit, Exit;
Circle 2, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Axyz 0, -1, -7.1, -19.9, 0, 0;
Axyz 0, -1, -7.22054, -19.89271, 0, 0;
Axyz 0, -1, -7.33932, -19.87094, 0, 0;
Axyz 0, -1, -7.4546, -19.83502, 0, 0;
Axyz 0, -1, -7.56472, -19.78546, 0, 0;
Axyz 0, -1, -7.66806, -19.72298, 0, 0;
Axyz 0, -1, -7.76312, -19.64851, 0, 0;
Axyz 0, -1, -7.84851, -19.56312, 0, 0;
Axyz 0, -1, -7.92298, -19.46807, 0, 0;
Axyz 0, -1, -7.98546, -19.36472, 0, 0;
Axyz 0, -1, -8.03502, -19.25461, 0, 0;
Axyz 0, -1, -8.07094, -19.13932, 0, 0;
Axyz 0, -1, -8.09271, -19.02054, 0, 0;
Axyz 0, -1, -8.1, -18.9, 0, 0;
Axyz 1, -1, -8.1, 66, 0, 0;
ToolRetraction;
Tilt 0, 0, 0, 0, 2, 10;
Shift 0, 0, 0, 0;
) Sm_2dcontour12;

; !Please make sure that the language on your control is set to "en"!
; !Number of tools in use: 2!
T1 = 1;!probe D:5 L2:10 L3:10!
T2 = 2;!flat end mill D:10 L2:20 L3:30!
Condition 0, 0, 0 , startOperation, startOperation;
; !##########X_angle##########!
Label 1;
; ! ZMIN = -5!
Dynamics 3;
Submacro Sm_x_angle;
; !##########2D Contour1 (2)##########!
Label 2;
; ! ZMIN = -19.9!
Tool T2, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Finish = 1;!m/min!
Entry = 1;!m/min!
Exit = 1;!m/min!
Plunge = 0.33;!m/min!
Submacro Sm_2dcontour12;
; !###############################################!
ToolRetraction;
Clamping_position
