!Makro file ; V9.85D!
!mycomment!

!Please make sure that the language on your control is set to "en"!
_sprache 1;

Dimension 1;

Variable optional_stop, $Message, T2, startOperation, Op_Circularmill, Op_Threadmill;

Smakros Sm_Circularmill, Sm_Threadmill;

_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <Circularmill<1>, Threadmill<2>>", "Select the operation to start with. ";

(
ToolRetraction;
Shift 1, 0, 0, 0;
Tilt 1, 0, 0, 0, 0, 10;
Contour_smoothing 1, 0.012, 0.1, 110, 1;
Axyz 1, 30, -8, z6p, 0, 0;
Axyz 1, 30, -8, 16, 0, 0;
Axyz 1, 30, -8, 16, 0, 0;
Feed 1, 1, 1, 1;
Axyz 1, 30, -8, 16, 0, 0;
Axyz 1, 30, -8, 6, 0, 0;
Axyz 1, 30, -8, 5, 0, 0;
Feed 0.5, 0.5, 0.5, 0.5;
Axyz 0, 30, -8, 0, 0, 0;
Axyz 0, 30, -8, -2, 0, 0;
Feed 1, 1, 1, 1;
Circle 1, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 1, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Axyz 0, 30, -8, -2, 0, 0;
Feed 0.5, 0.5, 0.5, 0.5;
Axyz 0, 30, -8, -4, 0, 0;
Feed 1, 1, 1, 1;
Circle 1, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 1, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Axyz 0, 30, -8, -4, 0, 0;
Feed 0.5, 0.5, 0.5, 0.5;
Axyz 0, 30, -8, -5, 0, 0;
Feed 1, 1, 1, 1;
Circle 1, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 1, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 3, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 4.7375, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 0, 90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 90, 180, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, 180, -90, 0, 0, 2, 1, 0;
Circle 5.475, 0, 0, 0, -90, 0, 0, 0, 2, 1, 0;
Axyz 0, 30, -8, -5, 0, 0;
Axyz 1, 30, -8, 6, 0, 0;
Axyz 1, 30, -8, 16, 0, 0;
ToolRetraction;
Tilt 0, 0, 0, 0, 2, 10;
Shift 0, 0, 0, 0;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
Message $Message, 0, 0, 0;
$Message = "OK";
) Sm_circularmill;
(
Shift 1, 0, 0, 0;
Tilt 1, 0, 0, 0, 0, 10;
Contour_smoothing 1, 0.012, 0.1, 110, 1;
Axyz 1, -30, -8, z6p, 0, 0;
Axyz 1, -30, -8, 16, 0, 0;
Axyz 1, -30, -8, 16, 0, 0;
Feed 1, 1, 1, 1;
Axyz 1, -30, -8, 6,0,0;
Thread 0, 0, 15, 1, 0.8, 6, 5, 0, 1, 5, 60, 0, 1, 0;
Axyz 1, -30, -8, 16, 0, 0;
ToolRetraction;
Tilt 0, 0, 0, 0, 2, 10;
Shift 0, 0, 0, 0;
) Sm_threadmill;

; !Please make sure that the language on your control is set to "en"!
; !Number of tools in use: 1!
T2 = 2;!flat end mill D:9.525 L2:15.99999 L3:24!
Condition 0, 0, 0 , startOperation, startOperation;
; !##########Circular mill##########!
Label 1;
; ! ZMIN = -5!
Tool T2, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Submacro Sm_circularmill;
; !##########Thread mill##########!
Label 2;
; ! ZMIN = -5!
Tool T2, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Submacro Sm_threadmill;
; !###############################################!
ToolRetraction;
Clamping_position
