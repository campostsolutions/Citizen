Axyz 1, 0.00032, -1.56345, 1.21835, 0, 0;
Axyz 1, 0.00032, -1.56345, 1.05701, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 0, 0.00032, -1.56345, 0.11001, 0, 0;
Axyz 1, 0.00032, -1.56345, 1.21835, 0, 0;
Axyz 1, 0.00032, -1.56345, 1.61835, 0, 0;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
