!Makro file ; V9.09F!
!mycomment!

!Please make sure that the language on your control is set to "en"!
_sprache 1;

Dimension 2;

Variable optional_stop, $Message, T3, startOperation, Op_Drill44_drilling_1, Op_Drill442_drilling_2, Op_Drill443_drilling_3, Op_Drill444_drilling_4, Op_Drill445_drilling_5, X_initial_pos, Y_initial_pos, Z_initial_pos, A_initial_pos, B_initial_pos, C_initial_pos, X_delta, Y_delta, Z_delta, A_delta, B_delta, C_delta, X, Y, Z, A, B, C, Israpid, X_trans, Y_trans, Z_trans, X_new, Y_new, Z_new, X_temp, Y_temp, Z_temp, A_temp, B_temp, C_temp, Isinitialposition, timefeed, Curr_zpno, Zpos;

Smakros Sm_Drill44_drilling_1, Sm_Drill442_drilling_2, Sm_Drill443_drilling_3, Sm_Drill444_drilling_4, Sm_Drill445_drilling_5, Initposition, Endmacro, Transformpath, Transformoffset, Retractzmax;

_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <Drill44_drilling_1<1>, Drill442_drilling_2<2>, Drill443_drilling_3<3>, Drill444_drilling_4<4>, Drill445_drilling_5<5>>", "Select the operation to start with. ";

_exit Endmacro;

_maske Transformoffset, 4, 0, "create a new coordinate system with the given rotation values"
_feld A, 4, 8, 0, -9999, 9999, 0, 1, "alpha", "rotation around x axis"
_feld B, 4, 8, 0, -9999, 9999, 0, 1, "beta", "rotation around Y"
_feld C, 4, 8, 0, -9999, 9999, 0, 1, "gamma", "rotation around Z";

_maske Transformpath, 9, 0, "create a new coordinate system with the given rotation values"
_feld Israpid, 4, 5, 0, -9999, 9999, 2, 0, "Is rapid", "is rapid"
_feld Isinitialposition, 4, 3, 0, -9999, 9999, 2, 1, "Isinitialposition", "If set machine positioning with z max height"
_feld X, 4, 5, 0, -9999, 9999, 0, 1, "X Value", "X Position"
_feld Y, 4, 5, 0, -9999, 9999, 0, 1, "Y Value", "Y Position"
_feld Z, 4, 5, 0, -9999, 9999, 0, 1, "Z Value", "Z Position"
_feld A, 4, 8, 0, -9999, 9999, 0, 1, "alpha", "rotation around x axis"
_feld B, 4, 8, 0, -9999, 9999, 0, 1, "beta", "rotation around Y"
_feld C, 4, 8, 0, -9999, 9999, 0, 1, "gamma", "rotation around Z"
_feld timefeed, 4, 8, 0, 0, 45000, 0, 1, "time in seconds", "movement duration for the current line segment";

(
X_initial_pos = X6p;
Y_initial_pos = Y6p;
Z_initial_pos = Z6p;
A_initial_pos = A6p;
B_initial_pos = B6p;
C_initial_pos = C6p;
Position 19, 2;
X_delta = X_initial_pos - X6p;
Y_delta = Y_initial_pos - Y6p;
Z_delta = Z_initial_pos - Z6p;
A_delta = A_initial_pos - A6p;
B_delta = B_initial_pos - B6p;
C_delta = C_initial_pos - C6p;
) Initposition;
(
Submacro Transformoffset 0, 0, 0, 0;
) Endmacro;
(
Position 19, 2;
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X6p + X_trans;
Y_new = Y6p + Y_trans;
Z_new = Z6p + Z_trans;
;!set new position!;
Setzp X_new, Y_new, Z_new;
) Transformoffset;
(
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X - X_trans;
Y_new = Y - Y_trans;
Z_new = ( ( Isinitialposition + 1 ) % 2 ) * ( Z - Z_trans ) + Isinitialposition * Z6max;
A_temp =  A - A_delta;
B_temp = B - B_delta;
C_temp = C - C_delta;
Axyzabc Israpid, X_new, Y_new, Z_new, A_temp, 0, C_temp;
) Transformpath;
(
Curr_zpno = Zeromemnr;
Zeromem 0;
Zpos = - Wzl - 0.5;
Axyz 1, Xp, Yp, Zpos, 0, 0;
Zeromem Curr_zpno;
) Retractzmax;
(
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Submacro Retractzmax;
A_temp = -30 - A_delta;
B_temp = b6p - B_delta;
C_temp = 0 - C_delta;
Axyzabc 1, x6p, y6p, z6p, A_temp, B_temp, C_temp;
Submacro Transformoffset 0,  -30,  0,  0;
Contour_smoothing 1, 0.0024, 0.1, 110, 1;
Axyz 1, 0.07734, -0.71114, z6p, 0, 0;
Axyz 1, 0.07734, -0.71114, 1.12622, 0, 0;
Axyz 1, 0.07734, -0.71114, 1.12622, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 1, 0.07734, -0.71114, 1.12622, 0, 0;
Axyz 1, 0.07734, -0.71114, 0.72622, 0, 0;
Axyz 1, 0.07734, -0.71114, 0.56488, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 0, 0.07734, -0.71114, -0.36562, 0, 0;
Axyz 1, 0.07734, -0.71114, 0.72622, 0, 0;
Axyz 1, 0.07734, -0.71114, 1.12622, 0, 0;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
Message $Message, 0, 0, 0;
$Message = "OK";
) Sm_drill44_drilling_1;
(
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Submacro Retractzmax;
A_temp = -30 - A_delta;
B_temp = b6p - B_delta;
C_temp = -90 - C_delta;
