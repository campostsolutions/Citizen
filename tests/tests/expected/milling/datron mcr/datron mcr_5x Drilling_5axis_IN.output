; !Please make sure that the language on your control is set to "en"!
; !Number of tools in use: 1!
T3 = 3;!drill D:0.20118 L2:0.98425 L3:1.1811!
; !Workpiece dimensions:!
; !min:     X: - 1.9685; Y: - 0.9843; Z: - 1.9685!
; !max:     X: + 1.9685; Y: + 0.9843; Z: + 0.0394!
; !Part size X: + 3.9370; Y: + 1.9685; Z: + 2.0079!
Wdef 3.93701, 1.9685, 2.00787, -1.9685, -0.98425, 0.03937, 0;
Submacro Initposition;
Condition 0, 0, 0 , startOperation, startOperation;
; !##########Drill44_drilling_1##########!
Label 1;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 1;
Position 19, 2;
Submacro Sm_drill44_drilling_1;
; !##########Drill44 (2)_drilling_2##########!
Label 2;
