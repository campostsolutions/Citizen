_sprache 1;

Dimension 1;

Variable optional_stop, $Message, T1, T2, startOperation, Op_Y_angle__1, Op_2dcontour13__2, Finish, Entry, Exit, Plunge, Curr_zpno, Zpos, Xvalue1, Xvalue2, Yvalue1, Yvalue2, Zvalue, Newpos, Rotationvalue;

Smakros Sm_Y_angle__1, Sm_2dcontour13__2, Retractzmax;

_maske _haupt, 1000, 0, "Submacro Description"
