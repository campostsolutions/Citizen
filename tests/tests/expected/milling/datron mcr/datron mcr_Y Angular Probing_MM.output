(
Curr_zpno = Zeromemnr;
Zeromem 0;
Zpos = - Wzl - 10;
Axyz 1, Xp, Yp, Zpos, 0, 0;
Zeromem Curr_zpno;
) Retractzmax;
(
T3d 9, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Rpm 0, 30, 0, 30;
Submacro Retractzmax;
Axyz 1, 240, -24.5, z6p, 0, 0;
Axyz 1, 240, -24.5, 66, 0, 0;
Axyz 1, 240, -24.5, 66, 0, 0;
Feed 1, 1, 1, 1;
Axyz 1, 240, -24.5, 56, 0, 0;
Axyz 1, 250, -24.5, 56, 0, 0;
Axyz 0, 250, -24.5, -25, 0, 0;
Yvalue1 = -5;
Yvalue2 = -5;
Taxyz 2, X6p, Yvalue1, Z6p, 1, 0, 0;
Axyz 1, x6p, y6p, 56, 0, 0;
Axyz 1, 230, -24.5, 56, 0, 0;
Axyz 0, 230, -24.5, -25, 0, 0;
Taxyz 2, X6p, Yvalue2, Z6p, 1, 0, 0;
Rotationvalue = Arctan ( ( Yvalue2 - Yvalue1 ) / (250-230) );
Rotation Rotationvalue, 1, 1, 1, 0, 0;
Axyz 1, X6p, Y6p, 56, 0, 0;
Axyz 1, 240, -24.5, 56, 0, 0;
Position 1, 3;
Axyz 1, 240, -24.5, 66, 0, 0;
Rpm 1, 30, 0, 30;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
Message $Message, 0, 0, 0;
$Message = "OK";
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
) Sm_y_angle__1;
(
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Contour_smoothing 1, 0.012, 0.1, 110, 1;
Axyz 1, 81, -8.1, z6p, 0, 0;
Axyz 1, 81, -8.1, 66, 0, 0;
Axyz 1, 81, -8.1, 66, 0, 0;
Axyz 1, 81, -8.1, 56, 0, 0;
Feed Plunge, Plunge, Plunge, Plunge;
Axyz 0, 81, -8.1, 52, 0, 0;
Axyz 0, 81, -8.1, -18.9, 0, 0;
Feed Entry, Entry, Entry, Entry;
Axyz 0, 81, -8.09271, -19.02054, 0, 0;
