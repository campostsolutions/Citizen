_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <Multi_axisfront__1<1>, 2d_facefront__2<2>, Multi_axisleft__3<3>, 2d_face1front__4<4>, Multi_axisback__5<5>, Multi_axisbackduplicate__6<6>, Multi_axisright__7<7>, Multi_axisrighttoolchange__8<8>, Multi_axisdiagonal__9<9>, 2dcontourtop__10<10>, Swarf1multiplespiral__11<11>, Swarfoutside__12<12>>", "Select the operation to start with. ";

_exit Endmacro;

_maske Transformoffset, 4, 0, "create a new coordinate system with the given rotation values"
_feld A, 4, 8, 0, -9999, 9999, 0, 1, "alpha", "rotation around x axis"
_feld B, 4, 8, 0, -9999, 9999, 0, 1, "beta", "rotation around Y"
_feld C, 4, 8, 0, -9999, 9999, 0, 1, "gamma", "rotation around Z";

_maske Transformpath, 9, 0, "create a new coordinate system with the given rotation values"
_feld Israpid, 4, 5, 0, -9999, 9999, 2, 0, "Is rapid", "is rapid"
_feld Isinitialposition, 4, 3, 0, -9999, 9999, 2, 1, "Isinitialposition", "If set machine positioning with z max height"
