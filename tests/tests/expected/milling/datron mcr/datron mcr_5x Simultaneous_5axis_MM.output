(
X_initial_pos = X6p;
Y_initial_pos = Y6p;
Z_initial_pos = Z6p;
A_initial_pos = A6p;
B_initial_pos = B6p;
C_initial_pos = C6p;
Position 19, 2;
X_delta = X_initial_pos - X6p;
Y_delta = Y_initial_pos - Y6p;
Z_delta = Z_initial_pos - Z6p;
A_delta = A_initial_pos - A6p;
B_delta = B_initial_pos - B6p;
C_delta = C_initial_pos - C6p;
) Initposition;
(
Submacro Transformoffset 0, 0, 0, 0;
) Endmacro;
(
Position 19, 2;
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X6p + X_trans;
Y_new = Y6p + Y_trans;
Z_new = Z6p + Z_trans;
;!set new position!;
Setzp X_new, Y_new, Z_new;
) Transformoffset;
(
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X - X_trans;
Y_new = Y - Y_trans;
Z_new = ( ( Isinitialposition + 1 ) % 2 ) * ( Z - Z_trans ) + Isinitialposition * Z6max;
A_temp =  A - A_delta;
B_temp = B - B_delta;
C_temp = C - C_delta;
Axyzabc Israpid, X_new, Y_new, Z_new, A_temp, 0, C_temp;
) Transformpath;
(
Curr_zpno = Zeromemnr;
