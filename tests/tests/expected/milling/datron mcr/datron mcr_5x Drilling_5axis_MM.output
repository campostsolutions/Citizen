) Sm_drill445_drilling_5;

; !Please make sure that the language on your control is set to "en"!
; !Number of tools in use: 1!
T3 = 3;!drill D:5.10997 L2:25 L3:29.99994!
; !Workpiece dimensions:!
; !min:     X: - 50.000; Y: - 25.000; Z: - 50.000!
; !max:     X: + 50.000; Y: + 25.000; Z: +  1.000!
; !Part size X: +100.000; Y: + 50.000; Z: + 51.000!
Wdef 100, 50, 51, -50, -25, 1, 0;
Submacro Initposition;
Condition 0, 0, 0 , startOperation, startOperation;
; !##########Drill44_drilling_1##########!
Label 1;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Position 19, 2;
Submacro Sm_drill44_drilling_1;
; !##########Drill44 (2)_drilling_2##########!
Label 2;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Submacro Sm_drill442_drilling_2;
; !##########Drill44 (3)_drilling_3##########!
Label 3;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 3;
Submacro Sm_drill443_drilling_3;
; !##########Drill44 (4)_drilling_4##########!
