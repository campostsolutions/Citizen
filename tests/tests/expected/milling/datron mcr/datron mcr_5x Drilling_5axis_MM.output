Submacro Retractzmax;
A_temp = -30 - A_delta;
B_temp = b6p - B_delta;
C_temp = 180 - C_delta;
Axyzabc 1, x6p, y6p, z6p, A_temp, B_temp, C_temp;
Submacro Transformoffset 0,  -30,  0,  180;
