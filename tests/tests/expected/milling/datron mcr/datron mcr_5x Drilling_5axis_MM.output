Axyz 1, 0.40098, -18.08764, z6p, 0, 0;
Axyz 1, 0.40098, -18.08764, 28.60603, 0, 0;
Axyz 1, 0.40098, -18.08764, 28.60603, 0, 0;
Feed 0.4, 0.4, 0.4, 0.4;
