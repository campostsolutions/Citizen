Rpm 3, 6, 0, 30;
Dynamics 3;
Submacro Sm_drill445_drilling_5;
; !###############################################!
Submacro Endmacro;
Submacro Retractzmax;
A_temp = 0 - A_delta;
B_temp = b6p - B_delta;
C_temp = 0 - C_delta;
Axyzabc 1, x6p, y6p, z6p, A_temp, B_temp, C_temp;
Submacro Transformoffset 0,  0,  0,  0;
Park;
