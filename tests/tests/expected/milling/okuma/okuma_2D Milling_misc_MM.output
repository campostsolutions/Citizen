(################## Tool Check SUB PROGRAM ##################)

OCHCK
(VC200 Tool Number)
(VC199 Tool Length)
(VC198 Tool Diameter)
VC195 = 0 (reset variable)

VC195 = VTPNO[VC200]

VC194 = VC199 + 1 (upper tool length limit)
VC193 = VC199 - 1 (lower tool Length limit)
VC192 = VC198 * 1.05 (upper tool radius limit)
VC191 = VC198 * 0.95 (lower tool radius limit)

N1 IF [VTOHT[VC200,10001] LT VC194] N5
VUACM[1]='TOOL LONG'
VDOUT[992]=1

N5 IF [VTOHT[VC200,10001] GT VC193] N10
VUACM[1]='TOOL SHORT'
VDOUT[992]=1

N10 IF [VTODT[[VC200,10001]] LT VC192] N15
VUACM[1]='T DIA LARGE'
VDOUT[992]=1

N15 IF [VTODT[[VC200,10001]] GT VC191] N20
VUACM[1]='T DIA SMALL'
VDOUT[992]=1

N20 RTS
