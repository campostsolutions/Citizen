//  --- INFO ---
// MYCOMMENT
//  --- INIT ---
TCorrOff                          // Deactivate RTCP function
RMO                               // Reset the rotary axis coordinates

// TOOLS
// -------------------------------------
//   T2 D=9.525 - FLAT END MILL
//   T8 D=12.7 - FLAT END MILL
// -------------------------------------
//  --- BEGIN MACHINING ---
// 2D-FACE DIAGONAL
T2
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP -ssa                           // Approach safety position as starting position
WaitC                             // Option: Program pause, if it was activated

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on

// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=22.208 ;C=45 // Zero point offset for rotary axis machines (no traversing movement)
G01 C45 F10000
G01 A22.208

HEADEREND                 // End of the program header

G00 X17.646 Y-31.846
G00 Z35.97
G00 Z25.97
G01 Z16.481 F500
G01 Y-31.853 Z16.366 F1000
G01 Y-31.874 Z16.253
G01 Y-31.908 Z16.143
G01 Y-31.955 Z16.039
G01 X17.647 Y-32.015 Z15.94
G01 Y-32.086 Z15.85
G01 Y-32.167 Z15.768
G01 Y-32.258 Z15.697
G01 X17.648 Y-32.356 Z15.638
G01 Y-32.461 Z15.591
G01 X17.649 Y-32.571 Z15.556
G01 Y-32.684 Z15.536
G01 Y-32.799 Z15.529
G01 X17.65 Y-33.027
G01 X17.716 Y-51.36
G01 Y-51.475 Z15.536
G01 X17.717 Y-51.588 Z15.556
G01 Y-51.698 Z15.591
G01 X17.718 Y-51.803 Z15.638
G01 Y-51.901 Z15.697
G01 Y-51.992 Z15.768
G01 X17.719 Y-52.073 Z15.85
G01 Y-52.144 Z15.94
G01 Y-52.203 Z16.039
G01 Y-52.251 Z16.143
G01 Y-52.285 Z16.253
G01 Y-52.305 Z16.366
G01 Y-52.312 Z16.481
G00 Z35.97
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F10000
G01 A0
 M30
