//  --- INFO ---
// MYCOMMENT
//  --- INIT ---
TCorrOff                          // Deactivate RTCP function
RMO                               // Reset the rotary axis coordinates

// TOOLS
// -------------------------------------
//   T2 D=9.525 - FLAT END MILL
//   T8 D=12.7 - FLAT END MILL
// -------------------------------------
//  --- BEGIN MACHINING ---
// 2D-FACE LEFT TOOLCHANGE
T2
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP -ssa                           // Approach safety position as starting position
WaitC                             // Option: Program pause, if it was activated

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on

// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=-90 // Zero point offset for rotary axis machines (no traversing movement)
G01 C-90 F10000
G01 A30

HEADEREND                 // End of the program header

G00 X31.488 Y-39.703
G00 Z40.866
G00 Z30.866
G01 Z22.72 F500
G01 X31.481 Z22.606 F1000
G01 X31.46 Z22.493
G01 X31.426 Z22.383
G01 X31.379 Z22.278
G01 X31.319 Z22.179
G01 X31.248 Z22.089
G01 X31.167 Z22.007
G01 X31.077 Z21.937
G01 X30.978 Z21.877
G01 X30.873 Z21.83
G01 X30.763 Z21.796
G01 X30.65 Z21.775
G01 X30.536 Z21.768
G01 X-32
G01 X-32.115 Z21.775
G01 X-32.228 Z21.796
G01 X-32.338 Z21.83
G01 X-32.443 Z21.877
G01 X-32.541 Z21.937
G01 X-32.632 Z22.007
G01 X-32.713 Z22.089
G01 X-32.784 Z22.179
G01 X-32.843 Z22.278
G01 X-32.891 Z22.383
G01 X-32.925 Z22.493
G01 X-32.946 Z22.606
G01 X-32.952 Z22.72
G00 Z40.866
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F10000
G01 A0
 M30
