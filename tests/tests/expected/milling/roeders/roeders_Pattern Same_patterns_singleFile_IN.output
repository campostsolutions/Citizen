//  --- INFO ---
// MYCOMMENT
//  --- INIT ---
Set_Offset_R -od -tor             // change calculation rule for 2D radius correction

PROTOCOL -start -head
MDC -Start -User1="Hauptprogramm"

//  --- BEGIN MACHINING ---
MaCoor -all                       // Reset all coordinate shifts
LoadZero="1"-h=0.0               // Example: Workpiece zero point from zero point memory

//  --- DYNAMIC ---
Cam_Undersize=0                   // Workpiece undersize (minimum oversize of all programs)
DynAuto="General"                 // ADPA rule"General"

//  --- OPTIONS ---
// SET_WARMUP=120                 // MANUAL USER SPINDLE WARMUP
// SET_OFFSET_R=0.00              // MANUAL USER OFFSET FOR 2D_COMPENSATION

// TOOLS
// -------------------------------------
//   T1 D=2 - ZMIN=-0.04 - ZMAX=0.5906 - FACE MILL
//   T2 D=0.375 - ZMIN=-0.4337 - ZMAX=0.5906 - FLAT END MILL
//   T3 D=0.2012 TAPER=118DEG - ZMIN=-0.691 - ZMAX=0.5906 - DRILL
// -------------------------------------

//  --- BEGIN MACHINING ---
// 2D-FACE 7

// --------------------------------------------------------------------------------------------------
//  T1, TT=MYTOOL1, TOOLDATA DIA=2, TIPR=0
// --------------------------------------------------------------------------------------------------
T1
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP -ssa                           // Approach safety position as starting position
WaitC                             // Option: Program pause, if it was activated

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X3.1896 Y-0.975
G00 Z0.5906
CALL LBL1

// 2D-FACE 7
MaCoor -all                       // Reset all coordinate shifts
LoadZero="2"-h=0.0               // Example: Workpiece zero point from zero point memory

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

G00 X3.1896 Y-0.975
G00 Z0.5906
CALL LBL1
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off

// 2D-CONTOUR WITH COMPENSATION LEFT 5
MaCoor -all                       // Reset all coordinate shifts
LoadZero="1"-h=0.0               // Example: Workpiece zero point from zero point memory


// --------------------------------------------------------------------------------------------------
//  T2, TT=MYTOOL2, TOOLDATA DIA=0.375, TIPR=0
// --------------------------------------------------------------------------------------------------
T2
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X-0.1377 Y1.1944
G00 Z0.5906
CALL LBL2

// 2D-CONTOUR WITH COMPENSATION LEFT 5
MaCoor -all                       // Reset all coordinate shifts
LoadZero="2"-h=0.0               // Example: Workpiece zero point from zero point memory

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

G00 X-0.1377 Y1.1944
G00 Z0.5906
CALL LBL2
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off

// RAPID OUT 7
MaCoor -all                       // Reset all coordinate shifts
LoadZero="1"-h=0.0               // Example: Workpiece zero point from zero point memory


// --------------------------------------------------------------------------------------------------
//  T3, TT=MYTOOL3, TOOLDATA DIA=0.2012, TIPR=0
// --------------------------------------------------------------------------------------------------
T3
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X-0.9843 Y0.3937
G00 Z0.5906
CALL LBL3

// RAPID OUT 7
MaCoor -all                       // Reset all coordinate shifts
LoadZero="2"-h=0.0               // Example: Workpiece zero point from zero point memory

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

G00 X-0.9843 Y0.3937
G00 Z0.5906
CALL LBL3
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off


//  RESET_WARMUP                  // RESETTING A TEMPORARY WARM-UP TIME
//  RESET_OFFSET_R                // INITIALIZE 2D-RADIUS CORRECTION OFFSET
//  LINEUP = 0


//  --- END OF MACHINING ---


MDC -End
