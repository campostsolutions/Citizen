// REAMING

// --------------------------------------------------------------------------------------------------
//  T6, TT=MYTOOL6, TOOLDATA DIA=5.08, TIPR=0
// --------------------------------------------------------------------------------------------------
T6
S2000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X-25 Y10
G00 Z16
CYCL DEF 201 REAMING ~
  Q200=5 ;SET-UP CLEARANCE ~
  Q201=-14 ;DEPTH ~
  Q206=200 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=200 ;RETRACTION FEED TIME ~
  Q203=0 ;SURFACE COORDINATE ~
  Q204=6 ;2ND SET-UP CLEARANCE
G00 M99
G00 X25 M99
G00 Z16
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off

// BORING

// --------------------------------------------------------------------------------------------------
//  T3, TT=MYTOOL3, TOOLDATA DIA=5.11, TIPR=0
// --------------------------------------------------------------------------------------------------
T3
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X-25 Y10
G00 Z16
CYCL DEF 202 BORING ~
  Q200=5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=400 ;RETRACTION FEED RATE ~
  Q203=0 ;SURFACE COORDINATE ~
  Q204=6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
G00 M99
G00 X25 M99
G00 Z16

// BORING RETRACT FEED
// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
SP                                // Safety position

G00 X-25 Y10
G00 Z16
CYCL DEF 202 BORING ~
  Q200=5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=1000 ;RETRACTION FEED RATE ~
  Q203=0 ;SURFACE COORDINATE ~
  Q204=6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
G00 M99
