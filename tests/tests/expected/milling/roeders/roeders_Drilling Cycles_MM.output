// RAPID MOVEMENT TEST

// --------------------------------------------------------------------------------------------------
//  T7, TT=MYTOOL7, TOOLDATA DIA=6.35, TIPR=0
// --------------------------------------------------------------------------------------------------
T7
S6000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.01                      // CAM tolerance
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on
G00 X-43.536 Y18.536
G00 Z9.9
CYCL DEF 200 DRILLING ~
  Q200=0 ;SET-UP CLEARANCE ~
  Q201=-0.1 ;DEPTH ~
  Q206=333 ;FEED RATE FOR PLUNGING ~
  Q202=0.1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.1 ;SURFACE COORDINATE ~
  Q204=0 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
G00 M99
G00 X0 Y-18.536 M99
G00 Z9.9
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off


//  RESET_WARMUP                  // RESETTING A TEMPORARY WARM-UP TIME
//  RESET_OFFSET_R                // INITIALIZE 2D-RADIUS CORRECTION OFFSET
//  LINEUP = 0


//  --- END OF MACHINING ---


MDC -End
 M30
