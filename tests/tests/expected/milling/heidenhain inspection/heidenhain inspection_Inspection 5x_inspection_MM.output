BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-31 Y-53 Z-126.5
BLK FORM 0.2 X+31 Y+12.5 Z+12.5
;-------------------------------------
;T1 D=+6 CR=+3 - probe
;T2 D=+10 CR=+5 - ball end mill
