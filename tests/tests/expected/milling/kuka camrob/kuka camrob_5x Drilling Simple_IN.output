&ACCESS RV
&REL 1
DEF KUKA CAMROB_5X DRILLING SIMPLE_IN()
;FOLD INI
  ;FOLD BASISTECH INI
    GLOBAL INTERRUPT DECL 3 WHEN $STOPMESS==TRUE DO IR_STOPM ( )
    GLOBAL INTERRUPT DECL 4 WHEN $IN[22]==FALSE DO IR_HMT ( )
    GLOBAL INTERRUPT DECL 5 WHEN HMTStopReq==TRUE DO IR_HMT ( )
    INTERRUPT ON 3
    INTERRUPT ON 4
    INTERRUPT ON 5
    BAS (#INITMOV,0 )
  ;ENDFOLD (BASISTECH INI)
  ;FOLD USER INI
  ;Make your modifications here
;mycomment

  ;ENDFOLD (USER INI)
;ENDFOLD (INI)

;Generated by AUTODESK Fusion CAM 2.0.20494

HMT_STARTUP()
HMT_PURGE()

; Set PTP velocity and acceleration
$VEL_AXIS[1] = 25
$VEL_AXIS[2] = 25
$VEL_AXIS[3] = 25
$VEL_AXIS[4] = 25
$VEL_AXIS[5] = 25
$VEL_AXIS[6] = 25
$ACC_AXIS[1] = 20
$ACC_AXIS[2] = 20
$ACC_AXIS[3] = 20
$ACC_AXIS[4] = 20
$ACC_AXIS[5] = 20
$ACC_AXIS[6] = 20

; Do not use acceleration defined in the CSV
cr_bupdate_acc=false

; To set 'Tool On Robot' Mode
$IPO_MODE = #BASE

; Set smoothing value
$APO.CDIS = 2
$APO.CDIS = 5
CR_rAPO_CDIS = $APO.CDIS

; Set $ADVANCE value (number of points read in advance)
$ADVANCE = 3

; Set BASE
BAS(#BASE,1)

;FOLD CAMRob.LoadTool = 1 [1..100];%{PE}%MKUKATPUSER
  CR_LOAD_TOOL( 3)
;ENDFOLD
BAS(#TOOL,3)
$TOOL = TOOL_DATA[3]

; Spindle ON/speed
CR_SPINDLE_VEL( 5000, #CLW)

;FOLD CAMRob.SpindleState = ON;%{PE}%MKUKATPUSER
  CR_SPINDLE(#ON)
;ENDFOLD


PTP {X 1.9643,Y -29.9459,Z 15.7421,A -156.587,B 12.921,C 153.435,E1 0,E2 0,E3 0,E4 0,E5 0,E6 0,S'B110',T'B110010'}
;FOLD CAMRob.ProcessFile = sDrill44_(11).csv, Start record = 1(1 = BEGIN) , End record = 7(-1 = END) , Checksum = OK ('OK' = No check) ;%{PE}%MKUKATPUSER
  CR_PROCESS_FILE("sDrill44_(11).csv", 1, 7, "OK")
;ENDFOLD

