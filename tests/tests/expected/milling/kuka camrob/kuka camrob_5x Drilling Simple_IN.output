PTP {X -54.9675,Y 2.6944,Z 15.7296,A -142.411,B 24.584,C -163.898,E1 0,E2 0,E3 0,E4 0,E5 0,E6 0,S'B110',T'B110010'}
;FOLD CAMRob.ProcessFile = sDrill44_(14).csv, Start record = 1(1 = BEGIN) , End record = 7(-1 = END) , Checksum = OK ('OK' = No check) ;%{PE}%MKUKATPUSER
  CR_PROCESS_FILE("sDrill44_(14).csv", 1, 7, "OK")
