PTP {X -0.4010,Y 29.9674,Z 15.7297,A -156.587,B -12.921,C -153.435,E1 0,E2 0,E3 0,E4 0,E5 0,E6 0,S'B110',T'B110010'}
;FOLD CAMRob.ProcessFile = sDrill44_(13).csv, Start record = 1(1 = BEGIN) , End record = 7(-1 = END) , Checksum = OK ('OK' = No check) ;%{PE}%MKUKATPUSER
  CR_PROCESS_FILE("sDrill44_(13).csv", 1, 7, "OK")
