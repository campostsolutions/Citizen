; Set PTP velocity and acceleration
$VEL_AXIS[1] = 25
$VEL_AXIS[2] = 25
$VEL_AXIS[3] = 25
$VEL_AXIS[4] = 25
$VEL_AXIS[5] = 25
$VEL_AXIS[6] = 25
