# Operation Time: 2s
# ZMIN = 0.88583
program Operation_3AxisInspection__1
  BeginBlock name="3AxisInspection__1"
  LoadWcs name="1"
  Smoothing On allowedDeviation=0.00047
  Dynamic = 5
  SafeZHeightForWorkpiece=1.47638
  Spindle Off
  PrepareXyzSensor
  PrePositioning X=-0.80709 Y=0 Z=1.47638
  InspectionFilename = "Setup1 milling RESULTS.txt"
  # delete existing old file
  if FileExists filename=InspectionFilename
    FileDelete filename=InspectionFilename
  endif
  
  FileWriteLine filename=InspectionFilename value="START"
  FileWriteLine filename=InspectionFilename value="DOCUMENTID f06057c0-1983-45ed-9e68-3abf8d573210"
  FileWriteLine filename=InspectionFilename value="MODELVERSION c656480c-f2b5-4def-a1de-79a8ebf2a079"
  FileWriteLine filename=InspectionFilename value="TOOLPATHID 4"
  FileWriteLine filename=InspectionFilename value="G331 N1 A0 B0 C0 X0 Y0 Z-0.49213"
  FileWriteLine filename=InspectionFilename value=";TOOLPATH 3 Axis Inspection"
  FileWriteLine filename=InspectionFilename value="G330 N1 A0 B0 C0 X0 Y0 Z0 I0 R0"
  # Geometry Only
  PrepareXyzSensor
  Rapid Z=0.88583
  MeasurePoint(
    pointID=1
    surfacePos=NewPos(-0.49213, 0, 0)
    measureDirection=NewPos(1, 0, -0.00001)
    searchDistance=0.19685
    surfaceOffset=0
    upper=0.0002
    lower=-0.0002)
  
  Rapid Z=0.88583
  Rapid X=0 Y=-0.80709
  MeasurePoint(
    pointID=2
    surfacePos=NewPos(0, -0.49213, 0)
    measureDirection=NewPos(0, 1, -0.00001)
    searchDistance=0.19685
    surfaceOffset=0
    upper=0.0002
    lower=-0.0002)
  
  Rapid Z=0.88583
  Rapid X=0.80709 Y=0
  MeasurePoint(
    pointID=3
    surfacePos=NewPos(0.49213, 0, 0.00001)
    measureDirection=NewPos(-1, 0, -0.00001)
    searchDistance=0.19685
    surfaceOffset=0
    upper=0.0002
    lower=-0.0002)
  
  Rapid Z=0.88583
  Rapid X=0 Y=0.80709
  MeasurePoint(
    pointID=4
    surfacePos=NewPos(0, 0.49213, 0)
    measureDirection=NewPos(0, -1, 0)
    searchDistance=0.19685
    surfaceOffset=0
    upper=0.0002
    lower=-0.0002)
  
  Rapid Z=0.88583
  Rapid X=0.00001 Y=0
  MeasurePoint(
    pointID=5
    surfacePos=NewPos(0, 0, 0.49213)
    measureDirection=NewPos(-0.00001, -0.00001, -1)
    searchDistance=0.19685
    surfaceOffset=0
    upper=0.0002
    lower=-0.0002)
  
  Rapid Z=0.88583
  Rapid Z=1.47638
  UnprepareXyzSensor
  FileWriteLine filename=InspectionFilename value="END"
  Dialog message="Finish Inspection" Yes No caption="Inspection" Info
  ToolCompensation Off
  PathCorrection Off
  UnprepareXyzSensor
  EndBlock
endprogram # Operation_3AxisInspection__1

