# Operation Time: 2s
# ZMIN = 22.5
program Operation_3AxisInspection__1
  BeginBlock name="3AxisInspection__1"
  LoadWcs name="1"
  Smoothing On allowedDeviation=0.012
  Dynamic = 5
  SafeZHeightForWorkpiece=37.5
  Spindle Off
  PrepareXyzSensor
  PrePositioning X=-20.5 Y=-0.00004 Z=37.5
  InspectionFilename = "Setup1 milling RESULTS.txt"
  # delete existing old file
  if FileExists filename=InspectionFilename
    FileDelete filename=InspectionFilename
  endif
  
  FileWriteLine filename=InspectionFilename value="START"
  FileWriteLine filename=InspectionFilename value="DOCUMENTID f06057c0-1983-45ed-9e68-3abf8d573210"
  FileWriteLine filename=InspectionFilename value="MODELVERSION c656480c-f2b5-4def-a1de-79a8ebf2a079"
  FileWriteLine filename=InspectionFilename value="TOOLPATHID 4"
  FileWriteLine filename=InspectionFilename value="G331 N1 A0 B0 C0 X0 Y0 Z-12.5"
  FileWriteLine filename=InspectionFilename value=";TOOLPATH 3 Axis Inspection"
  FileWriteLine filename=InspectionFilename value="G330 N1 A0 B0 C0 X0 Y0 Z0 I0 R0"
  # Geometry Only
  PrepareXyzSensor
  Rapid Z=22.5
  MeasurePoint(
    pointID=1
    surfacePos=NewPos(-12.5, -0.00003, 0.00008)
    measureDirection=NewPos(1, 0, -0.00001)
    searchDistance=5
    surfaceOffset=0
    upper=0.005
    lower=-0.005)
  
  Rapid Z=22.5
  Rapid X=-0.00002 Y=-20.5
  MeasurePoint(
    pointID=2
    surfacePos=NewPos(-0.00002, -12.5, 0.00008)
    measureDirection=NewPos(0, 1, -0.00001)
    searchDistance=5
    surfaceOffset=0
    upper=0.005
    lower=-0.005)
  
  Rapid Z=22.5
  Rapid X=20.5 Y=-0.0001
  MeasurePoint(
    pointID=3
    surfacePos=NewPos(12.5, -0.00006, 0.00017)
    measureDirection=NewPos(-1, 0, -0.00001)
    searchDistance=5
    surfaceOffset=0
    upper=0.005
    lower=-0.005)
  
  Rapid Z=22.5
  Rapid X=0.00005 Y=20.5
  MeasurePoint(
    pointID=4
    surfacePos=NewPos(0.00003, 12.5, 0)
    measureDirection=NewPos(0, -1, 0)
    searchDistance=5
    surfaceOffset=0
    upper=0.005
    lower=-0.005)
  
  Rapid Z=22.5
  Rapid X=0.00016 Y=0.00012
  MeasurePoint(
    pointID=5
    surfacePos=NewPos(0.0001, 0.00007, 12.5)
    measureDirection=NewPos(-0.00001, -0.00001, -1)
    searchDistance=5
    surfaceOffset=0
    upper=0.005
    lower=-0.005)
  
  Rapid Z=22.5
  Rapid Z=37.5
  UnprepareXyzSensor
  FileWriteLine filename=InspectionFilename value="END"
  Dialog message="Finish Inspection" Yes No caption="Inspection" Info
  ToolCompensation Off
  PathCorrection Off
  UnprepareXyzSensor
  EndBlock
endprogram # Operation_3AxisInspection__1

