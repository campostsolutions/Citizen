BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-0.433071 Y-0.433071 Z-1.574803
BLK FORM 0.2 X+19.330709 Y+19.330709 Z+2.007874
;-------------------------------------
;T1 D=+0.19685 CR=+0.098425 - ZMIN=-0.19685 - probe
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - Y Angle Probe Geometry
L X+1.968504 Y+1.968504 R0 FMAX M91
TOOL CALL 1 Z S50
L M140 MB MAX
L X+1.968504 Y+1.968504 R0 FMAX M91
L X+1.574803 Y-0.492126 R0 FMAX
L Z+8.110236 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 420 MEASURE ANGLE ~
  Q263=+1.181102 ;1ST POINT 1ST AXIS ~
  Q264=+0 ;1ST POINT 2ND AXIS ~
  Q265=+1.968504 ;2ND POINT 1ST AXIS ~
  Q266=+0 ;2ND POINT 2ND AXIS ~
  Q272=+2 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-0.098425 ;MEASURING HEIGHT ~
  Q320=+0.393701 ;SET-UP CLEARANCE ~
  Q260=+2.204724 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q281=+1 ;MEASURING LOG
L Z+8.110236 FMAX
FUNCTION FILECOPY "TCHPR420.TXT" TO "Y_Angle_Probe_Geometry"
FUNCTION FILEDELETE "TCHPR420.TXT"
M5
L M140 MB MAX
L X+1.968504 Y+1.968504 R0 FMAX M91
M30
END PGM 1234 INCH
