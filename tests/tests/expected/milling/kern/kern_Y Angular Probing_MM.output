BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-11 Y-11 Z-40
BLK FORM 0.2 X+491 Y+491 Z+51
;-------------------------------------
;T1 D=+5 CR=+2.5 - ZMIN=-25 - probe
;T2 D=+10 CR=+0 - ZMIN=-19.9 - flat end mill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - Y-angle
L X+50 Y+50 R0 FMAX M91
TOOL CALL 1 Z S50
TOOL DEF 2
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
L X+240 Y-24.5 R0 FMAX
L Z+66 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 400 BASIC ROTATION ~
  Q263=+230 ;1ST POINT 1ST AXIS ~
  Q264=-10 ;1ST POINT 2ND AXIS ~
  Q265=+250 ;2ND POINT 1ST AXIS ~
  Q266=-10 ;2ND POINT 2ND AXIS ~
  Q272=+2 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-22.5 ;MEASURING HEIGHT ~
  Q320=+12 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q307=+0 ;PRESET ROTATION ANG. ~
  Q305=+1 ;NUMBER IN TABLE
L Z+66 FMAX
L M140 MB MAX
;-------------------------------------
* - 2D Contour1 (3)
M5
L X+50 Y+50 R0 FMAX M91
M1
TOOL CALL 2 Z S5000
TOOL DEF 1
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M3
M8
FN 0: Q52=1000 ;Finish
FN 0: Q53=1000 ;Entry
FN 0: Q54=1000 ;Exit
FN 0: Q58=333.3 ;Plunge
L X+81 Y-8.1 R0 FMAX
L Z+66 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1 T+0.013
CYCL DEF 32.2 HSC-MODE:0
L Z+56 FMAX
L Z+52 FQ58
L Z-18.9
CC Y-7.1 Z-18.9
CP IPA+90 DR+ FQ53
L Y-6.1 Z-19.9
CC X+80 Y-6.1
CP IPA+90 DR+
L X+0 Y-5.1 FQ52
CC X+0 Y-6.1
CP IPA+90 DR+ FQ54
L X-1 Y-7.1
CC Y-7.1 Z-18.9
CP IPA-90 DR-
L Y-8.1 Z+66 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
M9
M5
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M30
END PGM 1234 MM
