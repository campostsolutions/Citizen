BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-31 Y-53 Z-126.5
BLK FORM 0.2 X+31 Y+12.5 Z+12.5
;-------------------------------------
;T1 D=+6 CR=+3 - ZMIN=+22.5 - probe
;-------------------------------------
DECLARE STRING QS1601 = "Inspection Commissioning mode active-See post Commissioning mode tool tip"
FN 16: F-PRINT TNC:\AUTODESK\MSR_MASK.a / SCREEN:
;In case the control does error here, make sure that the 'MSR_MASK.a' file
;is copied to the TNC into the folder 'TNC:\AUTODESK'.
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - 3 Axis Inspection
L X+50 Y+50 R0 FMAX M91
TOOL CALL 1 Z S50
;Renishaw OMP40-2 6mm x 50mm - Haas
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
L X-20.5 Y+0 R0 FMAX
L Z+37.5 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
;Load Calibration Data
FN 20: WAIT FOR SYNC
FN 18: SYSREAD Q1600=ID350 NR52 IDX1 ; Calibrated Radius
FN 18: SYSREAD Q1612=ID350 NR55 IDX2 ; Measure Feed
FN 18: SYSREAD Q1613=ID350 NR53 IDX1 ; Eccentricity X
FN 18: SYSREAD Q1614=ID350 NR53 IDX2 ; Eccentricity Y
FN 18: SYSREAD Q1615=ID350 NR51 ; Calibrated Length
FN 10: IF Q1615 NE +0 GOTO LBL "LENGTHOK1"
Q1615=Q114
LBL "LENGTHOK1"
Q1601=+3-Q1600
DECLARE STRING QS1601 = "START"
FN 16: F-PRINT TNC:\AUTODESK\MSR_MASK.a / Setup1_milling_RESULTS.MSR
