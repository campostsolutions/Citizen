BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-50 Y-25 Z-50
BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;"MYTOOL1" D=+50.8 CR=+0 - ZMIN=+0 - face mill
;"MYTOOL2" D=+9.525 CR=+0 - ZMIN=-10 - flat end mill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - 2D-Face
TOOL CALL "MYTOOL1" Z S5000
;myToolComment
TOOL DEF "MYTOOL2"
L M140 MB MAX
