BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-51.016 Y-26.016 Z-51.016
BLK FORM 0.2 X+51.016 Y+26.016 Z+0
;-------------------------------------
;T1 D=+50.8 CR=+0 - ZMIN=-1.016 - face mill
;T2 D=+9.525 CR=+0 - ZMIN=-11.016 - flat end mill
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-17.551 - drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - 2D-Face (7)
TOOL CALL 1 Z S5000
;myToolComment
TOOL DEF 2
L M140 MB MAX
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X+81.016 Y-24.765 R0 FMAX
L Z+15 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CALL LBL 100
L M140 MB MAX
;-------------------------------------
* - 2D-Face (7)
LBL 2
CYCL DEF 247 DATUM SETTING ~
  Q339=2 ; DATUM NUMBER
LBL 0
L X+81.016 Y-24.765 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 100
M9
L M140 MB MAX
;-------------------------------------
* - 2D-Contour with compensation left (5)
M5
M1
TOOL CALL 2 Z S5000
TOOL DEF 3
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-3.499 Y+30.339 R0 FMAX
L Z+15 R0 FMAX
M8
CALL LBL 101
L M140 MB MAX
;-------------------------------------
* - 2D-Contour with compensation left (5)
CALL LBL 2 ;DATUM
L X-3.499 Y+30.339 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 101
M9
L M140 MB MAX
;-------------------------------------
* - Rapid out (7)
M5
M1
TOOL CALL 3 Z S5000
TOOL DEF 1
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+15 R0 FMAX
M8
CALL LBL 102
L M140 MB MAX
;-------------------------------------
* - Rapid out (7)
CALL LBL 2 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 102
M9
M5
L M140 MB MAX
M30

LBL 100 ;2D-Face (7)
L Z+5 FMAX
L Z-1.016 F500
L X-81.016 F1000
CC X-81.016 Y-11.59
CP IPA-180 DR-
L X+81.016 Y+1.586
L Z+15 FMAX
LBL 0

LBL 101 ;2D-Contour with compensation left (5)
L Z+5 FMAX
L Z+1 F500
L Z-11.016
L X-8.737 Y+30.239 RL F1000
CC X-0.499 Y+30.239
CP IPA+90 DR+
L X+39 Y+22
CC X+39 Y+14
CP IPA-90 DR-
L X+47 Y-22
L X-42
CC X-42 Y-17
CP IPA-90 DR-
L X-47 Y+22
L X-0.499
CC X-0.499 Y+30.239
CP IPA+90 DR+
L X+2.501 Y+30.339 R0
L Z+15 FMAX
LBL 0

LBL 102 ;Rapid out (7)
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.535 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-1.016 ;SURFACE COORDINATE ~
  Q204=+6.016 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+15 FMAX
LBL 0

END PGM 1234 MM
