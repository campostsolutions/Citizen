BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-0.4331 Y-0.4331 Z-1.5748
BLK FORM 0.2 X+19.3307 Y+19.3307 Z+2.0079
;-------------------------------------
;T1 D=+0.1969 CR=+0.0984 - ZMIN=-0.1969 - probe
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - X Angle Probe Geometry
TOOL CALL 1 Z S50
L M140 MB MAX
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-0.4921 Y+1.5748 R0 FMAX
L Z+8.1102 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 420 MEASURE ANGLE ~
  Q263=+0 ;1ST POINT 1ST AXIS ~
  Q264=+1.9685 ;1ST POINT 2ND AXIS ~
  Q265=+0 ;2ND POINT 1ST AXIS ~
  Q266=+1.1811 ;2ND POINT 2ND AXIS ~
  Q272=+1 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-0.0984 ;MEASURING HEIGHT ~
  Q320=+0.3937 ;SET-UP CLEARANCE ~
  Q260=+2.2047 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q281=+1 ;MEASURING LOG
L Z+8.1102 FMAX
CALL LBL 1 ;DATUM
FUNCTION FILECOPY "TCHPR420.TXT" TO "X_Angle_Probe_Geometry"
FUNCTION FILEDELETE "TCHPR420.TXT"
M5
L M140 MB MAX
M30
END PGM 1234 INCH
