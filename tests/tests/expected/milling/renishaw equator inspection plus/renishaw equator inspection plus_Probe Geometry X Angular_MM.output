DMISMN/'1234 MYCOMMENT',05.2
FILNAM/'1234 MYCOMMENT',05.2
$$ =============================================================================
$$ T1 D=5. CR=2.5 - ZMIN=-5. - PROBE
$$ TURN OFF GAUGE COMPARISON OPERATION AT THE START OF THE PROGRAM
COMPARE/OFF
$$ SET UNITS AND DECIMAL PLACES TO METRIC
UNITS/MM,ANGDEC
DECPL/ALL,3
$$ ACTIVATE MACHINE COORDINATE SYSTEM
D(machine_coordinate_system)=DATSET/MCS
$$ -----------------------------------------------------------------------------
$$ RECALL INSPECTION LIBRARY OF DMIS MACROS
$$ -----------------------------------------------------------------------------
XTERN
EXTFIL/DMIS,'C:\Renishaw\Programs\Inspection+ for Renishaw Equator\MACROLibrary\Inspection+ macros for Renishaw Equator - Fanuc mill style.DMI'
ENDXTN
CALL/EXTERN,DMIS,M(Retract_to_clearance),Z
$$ -----------------------------------------------------------------------------
$$ X ANGLE PROBE GEOMETRY
$$ =============================================================================
CALL/EXTERN,DMIS,M(Turn_probe_on_9832),,SCANNING
CALL/EXTERN,DMIS,M(Recall_WCS),G54
WKPLAN/XYPLAN
CALL/EXTERN,DMIS,M(Protected_position_9810),-12.5,40.,206.
CALL/EXTERN,DMIS,M(Protected_position_9810),-12.5,40.,56.
CALL/EXTERN,DMIS,M(Protected_position_9810),-12.5,40.,-5.
CALL/EXTERN,DMIS,M(Line_measurement_9843),X,0.,20.,0,1,0,10.,B1.W2.0
GOTO/ZAXIS,58.5
CALL/EXTERN,DMIS,M(Protected_position_9810),-12.5,40.,206.

CALL/EXTERN,DMIS,M(Turn_probe_off_9833)

CALL/EXTERN,DMIS,M(Retract_to_clearance),Z
CALL/EXTERN,DMIS,M(Retract_to_clearance),XY
$$ -----------------------------------------------------------------------------
$$ END THE PROGRAM
$$ =============================================================================
ERROR/OFF
ENDFIL
