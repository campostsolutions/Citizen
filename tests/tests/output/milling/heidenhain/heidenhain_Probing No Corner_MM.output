BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-11 Y-11 Z-40
BLK FORM 0.2 X+491 Y+491 Z+51
;-------------------------------------
;T1 D=+5 CR=+2.5 - ZMIN=-25 - probe
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - X-probing (2)
TOOL CALL 1 Z S50
L M140 MB MAX
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-12.5 Y+40 R0 FMAX
L Z+66 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 419 DATUM IN ONE AXIS ~
  Q263=+0 ;1ST POINT 1ST AXIS ~
  Q264=+40 ;1ST POINT 2ND AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q272=+1 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q333=+0 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER
L Z+66 FMAX
CALL LBL 1 ;DATUM
L M140 MB MAX
;-------------------------------------
* - Y-probing (2) WCS override 2
LBL 2
CYCL DEF 247 DATUM SETTING ~
  Q339=2 ; DATUM NUMBER
LBL 0
L X+40 Y-12.5 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 419 DATUM IN ONE AXIS ~
  Q263=+40 ;1ST POINT 1ST AXIS ~
  Q264=+0 ;1ST POINT 2ND AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q272=+2 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q333=+0 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER
L Z+66 FMAX
CALL LBL 2 ;DATUM
;-------------------------------------
* - Z-probing (2) WCS override 2
CALL LBL 2 ;DATUM
L X+40 Y+40 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 417 DATUM IN TS AXIS ~
  Q263=+40 ;1ST POINT 1ST AXIS ~
  Q264=+40 ;1ST POINT 2ND AXIS ~
  Q294=+0 ;1ST POINT 3RD AXIS ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q333=+0 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER
L Z+66 FMAX
CALL LBL 2 ;DATUM
L M140 MB MAX
;-------------------------------------
* - X-channel (2)
CALL LBL 1 ;DATUM
L X+240 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 408 SLOT CENTER REF PT ~
  Q321=+240 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q311=+40 ;SLOT WIDTH ~
  Q272=+1 ;MEASURING AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+7 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+0 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q405=+240 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
L M140 MB MAX
;-------------------------------------
* - Y-channel (2) WCS override 7
LBL 3
CYCL DEF 247 DATUM SETTING ~
  Q339=7 ; DATUM NUMBER
LBL 0
L X+140 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 408 SLOT CENTER REF PT ~
  Q321=+140 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q311=+40 ;SLOT WIDTH ~
  Q272=+2 ;MEASURING AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+7 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+0 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q405=+240 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 3 ;DATUM
L M140 MB MAX
;-------------------------------------
* - X-wall (2)
CALL LBL 1 ;DATUM
L X+335 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 409 RIDGE CENTER REF PT ~
  Q321=+335 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q311=+50 ;RIDGE WIDTH ~
  Q272=+1 ;MEASURING AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+7 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q405=+335 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Y-wall (2)
CALL LBL 1 ;DATUM
L X+40 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 409 RIDGE CENTER REF PT ~
  Q321=+40 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q311=+40 ;RIDGE WIDTH ~
  Q272=+2 ;MEASURING AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+6 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q405=+240 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Circular hole (2)
CALL LBL 1 ;DATUM
L X+40 Y+140 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 412 DATUM INSIDE CIRCLE ~
  Q321=+40 ;CENTER IN 1ST AXIS ~
  Q322=+140 ;CENTER IN 2ND AXIS ~
  Q262=+80 ;NOMINAL DIAMETER ~
  Q325=+0 ;STARTING ANGLE ~
  Q247=+90 ;STEPPING ANGLE ~
  Q261=-22.5 ;MEASURING HEIGHT ~
  Q320=+5 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+0 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+40 ;DATUM ~
  Q332=+140 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM ~
  Q423=+4 ;NO. OF MEAS. POINTS ~
  Q365=+1 ;TYPE OF TRAVERSE
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Rectangular hole (2)
CALL LBL 1 ;DATUM
L X+140 Y+40 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 410 DATUM INSIDE RECTAN. ~
  Q321=+140 ;CENTER IN 1ST AXIS ~
  Q322=+40 ;CENTER IN 2ND AXIS ~
  Q323=+80 ;FIRST SIDE LENGTH ~
  Q324=+80 ;2ND SIDE LENGTH ~
  Q261=-22.5 ;MEASURING HEIGHT ~
  Q320=+8 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+0 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+140 ;DATUM ~
  Q332=+40 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Circular boss (2)
CALL LBL 1 ;DATUM
L X+140 Y+140 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 413 DATUM OUTSIDE CIRCLE ~
  Q321=+140 ;CENTER IN 1ST AXIS ~
  Q322=+140 ;CENTER IN 2ND AXIS ~
  Q262=+80 ;NOMINAL DIAMETER ~
  Q325=+0 ;STARTING ANGLE ~
  Q247=+90 ;STEPPING ANGLE ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+6 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+140 ;DATUM ~
  Q332=+140 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM ~
  Q423=+4 ;NO. OF MEAS. POINTS ~
  Q365=+1 ;TYPE OF TRAVERSE
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Rectangular boss (2)
CALL LBL 1 ;DATUM
L X+335 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 411 DATUM OUTS. RECTAN. ~
  Q321=+335 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q323=+50 ;FIRST SIDE LENGTH ~
  Q324=+80 ;2ND SIDE LENGTH ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+335 ;DATUM ~
  Q332=+240 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Circlular hole with island (2)
CALL LBL 1 ;DATUM
L X+440 Y+140 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 412 DATUM INSIDE CIRCLE ~
  Q321=+440 ;CENTER IN 1ST AXIS ~
  Q322=+140 ;CENTER IN 2ND AXIS ~
  Q262=+80 ;NOMINAL DIAMETER ~
  Q325=+0 ;STARTING ANGLE ~
  Q247=+90 ;STEPPING ANGLE ~
  Q261=-22.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+440 ;DATUM ~
  Q332=+140 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM ~
  Q423=+4 ;NO. OF MEAS. POINTS ~
  Q365=+1 ;TYPE OF TRAVERSE
L Z+66 FMAX
CALL LBL 1 ;DATUM
;-------------------------------------
* - Rectangular hole with island (2)
CALL LBL 1 ;DATUM
L X+440 Y+240 R0 FMAX
L Z+66 R0 FMAX
TCH PROBE 410 DATUM INSIDE RECTAN. ~
  Q321=+440 ;CENTER IN 1ST AXIS ~
  Q322=+240 ;CENTER IN 2ND AXIS ~
  Q323=+80 ;FIRST SIDE LENGTH ~
  Q324=+80 ;2ND SIDE LENGTH ~
  Q261=-22.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q331=+440 ;DATUM ~
  Q332=+240 ;DATUM ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q381=+0 ;PROBE IN TS AXIS ~
  Q382=+0 ;1ST CO. FOR TS AXIS ~
  Q383=+0 ;2ND CO. FOR TS AXIS ~
  Q384=+0 ;3RD CO. FOR TS AXIS ~
  Q333=+0 ;DATUM
L Z+66 FMAX
CALL LBL 1 ;DATUM
M5
L M140 MB MAX
M30
END PGM 1234 MM
