BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-50 Y-25 Z-50
BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-16.535 - drill
;T4 D=+6.35 CR=+0 - ZMIN=-14 - right hand tap
;T5 D=+6.35 CR=+0 - ZMIN=-14 - left hand tap
;T6 D=+5.08 CR=+0 - ZMIN=-14 - reamer
;T7 D=+6.35 CR=+0 TAPER=90deg - ZMIN=-0.2 - spot drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
* - Rapid out
TOOL CALL 3 Z S5000
TOOL DEF 4
L M140 MB MAX
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.535 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
* - Dwell and rapid out
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.535 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
* - Chip breaking
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 203 UNIVERSAL DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q212=+0.1 ;DECREMENT ~
  Q213=5 ;BREAKS ~
  Q205=+0.5 ;MIN. PLUNGING DEPTH ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q256=+0.102 ;DIST. FOR CHIP BRKNG
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
* - Deep drilling
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
* - Break-through drilling
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
L Z+6 FMAX
L Z+5 FMAX
L Z-11.425 F400
TOOL CALL Z S3000
L Z-16.535 F500
TOOL CALL Z S5000
L Z+5 F1000
L Z+6 FMAX
L X+25 FMAX
L Z+5 FMAX
L Z-11.425 F400
TOOL CALL Z S3000
L Z-16.535 F500
TOOL CALL Z S5000
L Z+5 F1000
L Z+6 FMAX
L Z+16 FMAX
* - Guided deep drilling
TOOL CALL Z S3000
M3
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 241 SINGLE-FLUTED DEEP-HOLE DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q379=+5.11 ;STARTING POINT ~
  Q253=500 ;F PRE-POSITIONING ~
  Q208=1000 ;RETRACT FEED RATE ~
  Q426=3 ;DIR. OF SPINDLE ROT. ~
  Q427=3000 ;ENTRY EXIT SPEED ~
  Q428=5000 ;DRILLING SPEED ~
  Q429=8 ;COOLANT ON ~
  Q430=9 ;COOLANT OFF ~
  Q435=+0 ;DWELL DEPTH
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Tap
M5
M1
TOOL CALL 4 Z S1000
TOOL DEF 5
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X+25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-14 ;DEPTH ~
  Q239=+1.27 ;THREAD PITCH ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE
L FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Left tap
M5
M1
TOOL CALL 5 Z S1000
TOOL DEF 4
L M140 MB MAX
M4
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-14 ;DEPTH ~
  Q239=-1.27 ;THREAD PITCH ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE
L FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Right tap
M5
M1
TOOL CALL 4 Z S1000
TOOL DEF 6
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X+25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-14 ;DEPTH ~
  Q239=+1.27 ;THREAD PITCH ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE
L FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Reaming
M5
M1
TOOL CALL 6 Z S2000
TOOL DEF 3
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 201 REAMING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-14 ;DEPTH ~
  Q206=200 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=200 ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Boring
M5
M1
TOOL CALL 3 Z S5000
TOOL DEF 7
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=400 ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
* - Boring Retract Feed
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=1000 ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
M9
L M140 MB MAX
* - Rapid movement test
M5
M1
TOOL CALL 7 Z S6000
TOOL DEF 3
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L X-43.536 Y+18.536 R0 FMAX
L Z+9.9 R0 FMAX
M8
CYCL DEF 200 DRILLING ~
  Q200=+0 ;SET-UP CLEARANCE ~
  Q201=-0.1 ;DEPTH ~
  Q206=333 ;FEED RATE FOR PLUNGING ~
  Q202=+0.1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.1 ;SURFACE COORDINATE ~
  Q204=+0 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+0 Y-18.536 FMAX M99
L Z+9.9 FMAX
M9
M5
L M140 MB MAX
M30
END PGM 1234 MM
