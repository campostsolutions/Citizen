BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-1.9685 Y-0.9843 Z-1.9685
BLK FORM 0.2 X+1.9685 Y+0.9843 Z+0.0394
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;T2 D=+0.375 CR=+0 - ZMIN=-0.1969 - flat end mill
;T3 D=+0.2012 CR=+0 TAPER=118deg - ZMIN=-0.651 - drill
;T4 D=+0.25 CR=+0 - ZMIN=-0.5512 - right hand tap
;T5 D=+0.25 CR=+0 - ZMIN=-0.5512 - left hand tap
;T6 D=+0.2 CR=+0 - ZMIN=-0.5512 - reamer
;T7 D=+0.25 CR=+0 TAPER=90deg - ZMIN=-0.0079 - spot drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
* - Rapid out (5)
TOOL CALL 3 Z S5000
TOOL DEF 4
L M140 MB MAX
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CALL LBL 100
* - Dwell and rapid out (4)
CALL LBL 1 ;DATUM
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
CALL LBL 101
* - Chip breaking (5)
