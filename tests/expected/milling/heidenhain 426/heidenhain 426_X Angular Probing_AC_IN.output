CYCL DEF 32.1
TCH PROBE 403 ROT IN ROTARY AXIS ~
  Q263=+0 ;1ST POINT 1ST AXIS ~
  Q264=+1.9685 ;1ST POINT 2ND AXIS ~
  Q265=+0 ;2ND POINT 1ST AXIS ~
  Q266=+1.1811 ;2ND POINT 2ND AXIS ~
  Q272=+1 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-0.0984 ;MEASURING HEIGHT ~
  Q320=+0.4724 ;SET-UP CLEARANCE ~
  Q260=+2.2047 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q312=+6 ;COMPENSATION AXIS ~
  Q337=+1 ;SET TO ZERO ~
  Q305=+1 ;NUMBER IN TABLE ~
  Q303=+1 ;MEAS. VALUE TRANSFER ~
  Q380=+0 ;REFERENCE ANGLE
L Z+2.5984 FMAX
CALL LBL 1 ;DATUM
L M140 MB MAX
* - 2D Contour1 (2)
M5
M1
TOOL CALL 2 Z S5000
TOOL DEF 1
L M140 MB MAX
M3
CALL LBL 1 ;DATUM
L A+0 C+0 R0 FMAX M94
CYCL DEF 19.0 WORKING PLANE
CYCL DEF 19.1 A+0 C+0 F99990
