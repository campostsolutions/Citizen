BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-1.9685 Y-0.9843 Z-1.9685
BLK FORM 0.2 X+1.9685 Y+0.9843 Z+0.0394
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;T3 D=+0.2012 CR=+0 TAPER=118deg - ZMIN=-0.5906 - drill
;-------------------------------------
L Z+0 R0 FMAX M92
;Stop Boring
TOOL CALL 3 Z S5000
M6
L Z+0 R0 FMAX M92
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 202 BORING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.5906 ;DEPTH ~
  Q206=157.48 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+0.9843 FMAX M99
L Z+0.6299 FMAX
;Fine Boring
CALL LBL 1 ;DATUM
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
CYCL DEF 202 BORING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.5906 ;DEPTH ~
  Q206=157.48 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+0.9843 FMAX M99
L Z+0.6299 FMAX
;Back Boring
CALL LBL 1 ;DATUM
L X-0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
CYCL DEF 204 BACK BORING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q249=+0.0079 ;DEPTH REDUCTION ~
  Q250=+0.5906 ;MATERIAL THICKNESS ~
  Q251=+0.0004 ;OFF-CENTER DISTANCE ~
  Q252=+0 ;TOOL EDGE HEIGHT ~
  Q253=MAX ;F PRE-POSITIONING ~
  Q254=157.48 ;F COUNTERBORING ~
  Q255=0 ;DWELL AT BOTTOM ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+0.9843 FMAX M99
L Z+0.6299 FMAX
M9
M5
L Z+0 R0 FMAX M92
M30
END PGM 1234 INCH
