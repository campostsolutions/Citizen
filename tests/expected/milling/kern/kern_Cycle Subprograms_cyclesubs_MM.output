BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-128 Y-64.5 Z-26.4
BLK FORM 0.2 X+128 Y+64.5 Z+0
;-------------------------------------
;T1 D=+10 CR=+0 TAPER=118deg - ZMIN=-29.9022 - center drill
;T3 D=+6.35 CR=+0 - ZMIN=-28.4 - right hand tap
