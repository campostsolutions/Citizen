CYCL DEF 32.1
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-2 ;DEPTH ~
  Q206=333.3 ;FEED RATE FOR PLUNGING ~
  Q202=+2 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
