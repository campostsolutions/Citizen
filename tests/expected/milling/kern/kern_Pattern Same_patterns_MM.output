BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-51.016 Y-26.016 Z-51.016
BLK FORM 0.2 X+51.016 Y+26.016 Z+0
;-------------------------------------
;T1 D=+50.8 CR=+0 - ZMIN=-1.016 - face mill
;T2 D=+9.525 CR=+0 - ZMIN=-11.016 - flat end mill
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-17.5512 - drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - 2D-Face (7)
L X+50 Y+50 R0 FMAX M91
TOOL CALL 1 Z S5000
;myToolComment
TOOL DEF 2
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M3
M8
FN 0: Q50=1000 ;Cutting
FN 0: Q52=1000 ;Finish
FN 0: Q57=500 ;Plunge
FN 0: Q59=1000 ;Transition
L X+81.016 Y-24.765 R0 FMAX
L Z+15 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1 T+0.013
CYCL DEF 32.2 HSC-MODE:1
CALL LBL 100
L M140 MB MAX
;-------------------------------------
* - 2D-Face (7)
L X+81.016 Y-24.765 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 100
M9
L M140 MB MAX
;-------------------------------------
* - 2D-Contour with compensation left (5)
M5
L X+50 Y+50 R0 FMAX M91
M1
TOOL CALL 2 Z S5000
TOOL DEF 3
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M3
M8
FN 0: Q52=1000 ;Finish
FN 0: Q53=1000 ;Entry
FN 0: Q54=1000 ;Exit
FN 0: Q58=500 ;Plunge
L X-3.4985 Y+30.3388 R0 FMAX
L Z+15 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1 T+0.013
CYCL DEF 32.2 HSC-MODE:0
CALL LBL 101
L M140 MB MAX
;-------------------------------------
* - 2D-Contour with compensation left (5)
L X-3.4985 Y+30.3388 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 101
M9
L M140 MB MAX
;-------------------------------------
* - Rapid out (7)
M5
L X+50 Y+50 R0 FMAX M91
M1
TOOL CALL 3 Z S5000
TOOL DEF 1
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M3
M8
L X-25 Y+10 R0 FMAX
L Z+15 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CALL LBL 102
L M140 MB MAX
;-------------------------------------
* - Rapid out (7)
L X-25 Y+10 R0 FMAX
L Z+15 R0 FMAX
CALL LBL 102
M9
M5
L M140 MB MAX
L X+50 Y+50 R0 FMAX M91
M30

LBL 100 ;2D-Face (7)
L Z+5 FMAX
L Z-1.016 FQ57
L X-81.016 FQ52
CC X-81.016 Y-11.5895
CP IPA-180 DR- FQ59
L X+81.016 Y+1.586 FQ52
L Z+15 FMAX
LBL 0

LBL 101 ;2D-Contour with compensation left (5)
L Z+5 FMAX
L Z+1 FQ58
L Z-11.016
L X-8.7373 Y+30.2388 RL FQ53
CC X-0.4985 Y+30.2388
CP IPA+90 DR+
L X+39 Y+22 FQ52
CC X+39 Y+14
CP IPA-90 DR-
L X+47 Y-22
L X-42
CC X-42 Y-17
CP IPA-90 DR-
L X-47 Y+22
L X-0.4985
CC X-0.4985 Y+30.2388
CP IPA+90 DR+ FQ54
L X+2.5015 Y+30.3388 R0
L Z+15 FMAX
LBL 0

LBL 102 ;Rapid out (7)
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.5352 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.5352 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-1.016 ;SURFACE COORDINATE ~
  Q204=+6.016 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+15 FMAX
LBL 0

END PGM 1234 MM
