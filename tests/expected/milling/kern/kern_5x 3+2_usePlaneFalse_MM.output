BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-50 Y-25 Z-50
BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;The postprocessor uses the following settings for CYCLE19:
;  Make sure that these settings match the settings on your machine.
;  MP7500 Bit1: 0 - Machine angles
;  MP7500 Bit2: 1 - The tilting axes are positioned with CYCLE19
;-------------------------------------
;Machine
;  description: AC_table_table
;T2 D=+9.525 CR=+0 - flat end mill
;T8 D=+12.7 CR=+0 - flat end mill
;-------------------------------------
M126
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
L X+0 Y+0 R0 FMAX M91
CYCL DEF 19.0 WORKING PLANE
CYCL DEF 19.1 A+0 C+0 F9999 ;RESET
;-------------------------------------
* - 2D-Face front
TOOL CALL 2 Z S5000
TOOL DEF 8
L M140 MB MAX
L X+0 Y+0 R0 FMAX M91
M3
M8
FN 0: Q52=1000 ;Finish
FN 0: Q53=1000 ;Entry
FN 0: Q54=1000 ;Exit
FN 0: Q57=500 ;Plunge
L A+30 C+0 R0 FMAX M94
