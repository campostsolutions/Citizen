!Makro file ; V9.09F!
!mycomment!

!Please make sure that the language on your control is set to "en"!
_sprache 1;

Dimension 2;

Variable optional_stop, $Message, T3, startOperation, Op_Drill42_drilling_1, Op_Drill43_drilling_2, Curr_zpno, Zpos;

Smakros Sm_Drill42_drilling_1, Sm_Drill43_drilling_2, Retractzmax;

_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <Drill42_drilling_1<1>, Drill43_drilling_2<2>>", "Select the operation to start with. ";

(
Curr_zpno = Zeromemnr;
Zeromem 0;
Zpos = - Wzl - 0.5;
Axyz 1, Xp, Yp, Zpos, 0, 0;
Zeromem Curr_zpno;
) Retractzmax;
(
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Submacro Retractzmax;
Axyzabc 1, x6p, y6p, z6p, a6p, 240, c6p;
Contour_smoothing 1, 0.0024, 0.1, 110, 1;
Axyz 1, -1.90157, 0, z6p, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 0, -1.90157, 0, 0.19685, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
$Message = "Start next Operation";
Condition optional_stop, 0, 1, 0, 9999;
Message $Message, 0, 0, 0;
$Message = "OK";
) Sm_drill42_drilling_1;
(
T3d 0, 0, 1, 15, 17, 10, 10, 10, 10, 10, 10;
Submacro Retractzmax;
Axyzabc 1, x6p, y6p, z6p, a6p, 120, c6p;
Contour_smoothing 1, 0.0024, 0.1, 110, 1;
Axyz 1, -1.90157, 0, z6p, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Feed 15.75, 15.75, 15.75, 15.75;
Axyz 0, -1.90157, 0, 0.19685, 0, 0;
Axyz 1, -1.90157, 0, 1.18425, 0, 0;
Axyz 1, -1.90157, 0, 1.58425, 0, 0;
) Sm_drill43_drilling_2;

; !Please make sure that the language on your control is set to "en"!
; !Number of tools in use: 1!
T3 = 3;!drill D:0.20118 L2:0.98425 L3:1.1811!
; !Workpiece dimensions:!
; !min:     X: - 4.0000; Y: - 0.9843; Z: - 0.9843!
; !max:     X: + 0.0000; Y: + 0.9843; Z: + 0.9843!
; !Part size X: + 4.0000; Y: + 1.9685; Z: + 1.9685!
Wdef 4, 1.9685, 1.9685, -4, -0.98425, 0.98425, 0;
Condition 0, 0, 0 , startOperation, startOperation;
; !##########Drill42_drilling_1##########!
Label 1;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 1;
Submacro Sm_drill42_drilling_1;
; !##########Drill43_drilling_2##########!
Label 2;
Tool T3, 0, 0, 1, 0;
Rpm 3, 6, 0, 30;
Dynamics 1;
Submacro Sm_drill43_drilling_2;
; !###############################################!
Submacro Retractzmax;
Axyzabc 1, x6p, y6p, z6p, a6p, 0, c6p;
Park;
