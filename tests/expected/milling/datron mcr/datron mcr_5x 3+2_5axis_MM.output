Variable optional_stop, $Message, T2, T8, startOperation, Op_2d_facefront__1, Finish, Entry, Exit, Plunge, Op_2d_faceleft__2, Op_2d_facelefttoolchange__3, Op_2d_faceback__4, Op_2d_facebackduplicate__5, Op_2dcontourtop__6, Op_2d_faceright__7, Op_2d_facediagonal__8, X_initial_pos, Y_initial_pos, Z_initial_pos, A_initial_pos, B_initial_pos, C_initial_pos, X_delta, Y_delta, Z_delta, A_delta, B_delta, C_delta, X, Y, Z, A, B, C, Israpid, X_trans, Y_trans, Z_trans, X_new, Y_new, Z_new, X_temp, Y_temp, Z_temp, A_temp, B_temp, C_temp, Isinitialposition, timefeed, Curr_zpno, Zpos;

Smakros Sm_2d_facefront__1, Sm_2d_faceleft__2, Sm_2d_facelefttoolchange__3, Sm_2d_faceback__4, Sm_2d_facebackduplicate__5, Sm_2dcontourtop__6, Sm_2d_faceright__7, Sm_2d_facediagonal__8, Initposition, Endmacro, Transformpath, Transformoffset, Retractzmax;

_maske _haupt, 1000, 0, "Submacro Description"
_feld optional_stop, 1, 0, 0, 0, 1, 2, 0, "optional_stop", "optional_stop"
_feld startOperation, 1, 0, 1, 0, 9999, 1, 0, "Startoperation <2d_facefront__1<1>, 2d_faceleft__2<2>, 2d_facelefttoolchange__3<3>, 2d_faceback__4<4>, 2d_facebackduplicate__5<5>, 2dcontourtop__6<6>, 2d_faceright__7<7>, 2d_facediagonal__8<8>>", "Select the operation to start with. ";

_exit Endmacro;

_maske Transformoffset, 4, 0, "create a new coordinate system with the given rotation values"
_feld A, 4, 8, 0, -9999, 9999, 0, 1, "alpha", "rotation around x axis"
_feld B, 4, 8, 0, -9999, 9999, 0, 1, "beta", "rotation around Y"
_feld C, 4, 8, 0, -9999, 9999, 0, 1, "gamma", "rotation around Z";

_maske Transformpath, 9, 0, "create a new coordinate system with the given rotation values"
_feld Israpid, 4, 5, 0, -9999, 9999, 2, 0, "Is rapid", "is rapid"
_feld Isinitialposition, 4, 3, 0, -9999, 9999, 2, 1, "Isinitialposition", "If set machine positioning with z max height"
_feld X, 4, 5, 0, -9999, 9999, 0, 1, "X Value", "X Position"
_feld Y, 4, 5, 0, -9999, 9999, 0, 1, "Y Value", "Y Position"
_feld Z, 4, 5, 0, -9999, 9999, 0, 1, "Z Value", "Z Position"
_feld A, 4, 8, 0, -9999, 9999, 0, 1, "alpha", "rotation around x axis"
_feld B, 4, 8, 0, -9999, 9999, 0, 1, "beta", "rotation around Y"
_feld C, 4, 8, 0, -9999, 9999, 0, 1, "gamma", "rotation around Z"
_feld timefeed, 4, 8, 0, 0, 45000, 0, 1, "time in seconds", "movement duration for the current line segment";

(
X_initial_pos = X6p;
Y_initial_pos = Y6p;
Z_initial_pos = Z6p;
A_initial_pos = A6p;
B_initial_pos = B6p;
C_initial_pos = C6p;
Position 19, 2;
X_delta = X_initial_pos - X6p;
Y_delta = Y_initial_pos - Y6p;
Z_delta = Z_initial_pos - Z6p;
A_delta = A_initial_pos - A6p;
B_delta = B_initial_pos - B6p;
C_delta = C_initial_pos - C6p;
) Initposition;
(
Submacro Transformoffset 0, 0, 0, 0;
) Endmacro;
(
Position 19, 2;
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X6p + X_trans;
Y_new = Y6p + Y_trans;
Z_new = Z6p + Z_trans;
;!set new position!;
Setzp X_new, Y_new, Z_new;
) Transformoffset;
(
X_temp = X_delta;
Y_temp = Y_delta;
Z_temp = Z_delta;
;!Rotation around C!;
X_trans = X_temp * Cos ( C ) - Y_temp * Sin ( C );
Y_trans = X_temp * Sin ( C ) + Y_temp * Cos ( C );
Z_trans = Z_temp;
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Rotation around A!;
X_trans = X_temp;
Y_trans = Y_temp * Cos ( A ) - Z_temp * Sin ( A );
Z_trans = Y_temp * Sin ( A ) + Z_temp * Cos ( A );
X_temp = X_trans;
Y_temp = Y_trans;
Z_temp = Z_trans;
;!Calc new Position!;
X_new = X - X_trans;
Y_new = Y - Y_trans;
Z_new = ( ( Isinitialposition + 1 ) % 2 ) * ( Z - Z_trans ) + Isinitialposition * Z6max;
A_temp =  A - A_delta;
B_temp = B - B_delta;
C_temp = C - C_delta;
Axyzabc Israpid, X_new, Y_new, Z_new, A_temp, 0, C_temp;
) Transformpath;
(
Curr_zpno = Zeromemnr;
Zeromem 0;
Zpos = - Wzl - 10;
Axyz 1, Xp, Yp, Zpos, 0, 0;
Zeromem Curr_zpno;
) Retractzmax;
