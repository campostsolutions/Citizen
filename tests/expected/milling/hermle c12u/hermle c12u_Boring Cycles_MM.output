0 BEGIN PGM 1234 MM
1 ;mycomment
2 BLK FORM 0.1 Z X-50 Y-25 Z-50
3 BLK FORM 0.2 X+50 Y+25 Z+1
4 ;-------------------------------------
5 ;Tools
6 ;  #3 D=5.11 TAPER=118deg - ZMIN=-15 - ZMAX=+16 - drill
7 ;-------------------------------------
8 ;
9 M25
10 PLANE RESET STAY
11 * - Stop Boring
12 M5
13 TOOL CALL 3 Z S5000
14 L M140 MB MAX
15 M3
16 LBL 1
17 CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
18 LBL 0
19 M25
20 PLANE RESET TURN FMAX
21 M26
22 L X-25 Y+10 R0 FMAX
23 L Z+16 R0 FMAX
24 M8
25 CYCL DEF 32.0 TOLERANCE
26 CYCL DEF 32.1
27 CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
28 L FMAX M99
29 L X+25 FMAX M99
30 L Z+16 FMAX
31 * - Fine Boring
32 M3
33 CALL LBL 1 ;DATUM
34 M26
35 L X-25 Y+10 R0 FMAX
36 L Z+16 R0 FMAX
37 CYCL DEF 32.0 TOLERANCE
38 CYCL DEF 32.1
39 CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED TIME ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
40 L FMAX M99
41 L X+25 FMAX M99
42 L Z+16 FMAX
43 * - Back Boring
44 M3
45 CALL LBL 1 ;DATUM
46 M26
47 L X-25 Y+10 R0 FMAX
48 L Z+16 R0 FMAX
49 CYCL DEF 32.0 TOLERANCE
50 CYCL DEF 32.1
51 CYCL DEF 204 BACK BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q249=+0.2 ;DEPTH REDUCTION ~
  Q250=+15 ;MATERIAL THICKNESS ~
  Q251=+0.01 ;OFF-CENTER DISTANCE ~
  Q252=+0 ;TOOL EDGE HEIGHT ~
  Q253=MAX ;F PRE-POSITIONING ~
  Q254=400 ;F COUNTERBORING ~
  Q255=0 ;DWELL AT BOTTOM ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
52 L FMAX M99
53 L X+25 FMAX M99
54 L Z+16 FMAX
55 CYCL DEF 32.0 TOLERANCE
56 CYCL DEF 32.1
57 M9
58 M5
59 M25
60 L M140 MB MAX
61 L A+0 C+0 FMAX M94
62 M127
63 M30
64 END PGM 1234 MM
