0 BEGIN PGM 1234 MM
1 ;mycomment
2 BLK FORM 0.1 Z X-50 Y-25 Z-50
3 BLK FORM 0.2 X+50 Y+25 Z+1
4 ;-------------------------------------
5 ;Tools
6 ;  #3 D=5.11 TAPER=118deg - ZMIN=-16.535 - ZMAX=+16 - drill
7 ;-------------------------------------
8 ;
9 M25
10 PLANE RESET STAY
11 * - Rapid out (3)
12 M5
13 TOOL CALL 3 Z S5000
14 L M140 MB MAX
15 M3
16 LBL 1
17 CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
18 LBL 0
19 M25
20 PLANE RESET TURN FMAX
21 M26
22 L X-25 Y+10 R0 FMAX
23 L Z+16 R0 FMAX
24 M8
25 CYCL DEF 32.0 TOLERANCE
26 CYCL DEF 32.1
27 CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.535 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
28 L FMAX M99
29 L X+25 FMAX M99
30 L Z+16 FMAX
31 * - Chip breaking (3)
32 M3
33 CALL LBL 1 ;DATUM
34 M26
35 L X-25 Y+10 R0 FMAX
36 L Z+16 R0 FMAX
37 CYCL DEF 32.0 TOLERANCE
38 CYCL DEF 32.1
39 CYCL DEF 203 UNIVERSAL DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q212=+0.1 ;DECREMENT ~
  Q213=5 ;BREAKS ~
  Q205=+0.5 ;MIN. PLUNGING DEPTH ~
  Q211=0 ;DWELL TIME AT DEPTH ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q256=+0.102 ;DIST. FOR CHIP BRKNG
40 L FMAX M99
41 L X+25 FMAX M99
42 L Z+16 FMAX
43 * - Deep drilling (3)
44 M3
45 CALL LBL 1 ;DATUM
46 M26
47 L X-25 Y+10 R0 FMAX
48 L Z+16 R0 FMAX
49 CYCL DEF 32.0 TOLERANCE
50 CYCL DEF 32.1
51 CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
52 L FMAX M99
53 L X+25 FMAX M99
54 L Z+16 FMAX
55 CYCL DEF 32.0 TOLERANCE
56 CYCL DEF 32.1
57 M9
58 M5
59 M25
60 L M140 MB MAX
61 L A+0 C+0 FMAX M94
62 M127
63 M30
64 END PGM 1234 MM
