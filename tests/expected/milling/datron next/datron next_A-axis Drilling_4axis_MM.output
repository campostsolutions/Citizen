sequence SEQUENCE_Drill42_drilling_1
sequence SEQUENCE_Drill43_drilling_2

using Base
using Rtcp



export program Main #  1234 MM
  Absolute
  MultiAxisMode On
  Operation_Drill42_drilling_1
  Operation_Drill43_drilling_2
  SpraySystem Off
  MultiAxisMode Off
  MoveToSafetyPosition
  Rapid A=0
  Spindle Off
  MoveToParkPosition
endprogram # 1234 MM

# Operation Time: 3s
program Operation_Drill42_drilling_1
  BeginBlock name="Drill42_drilling_1"
  Smoothing On allowedDeviation=0.012
  Dynamic = 5
  MoveToSafetyPosition
  Rapid A=240
  SafeZHeightForWorkpiece=40.24
  SprayTechnology External
  Coolant Alcohol
  SpraySystem On
  Tool name="3_Drill_D511_myTool3" newRpm=5000 skipRestoring
  # Parameter drilling cycle
  SetFeedTechnology plunge=400
  SEQUENCE_Drill42_drilling_1 
  EndBlock
endprogram # Operation_Drill42_drilling_1

# Operation Time: 3s
program Operation_Drill43_drilling_2
  BeginBlock name="Drill43_drilling_2"
