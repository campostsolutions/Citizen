FN 27: TABWRITE 136/"PARAM" = Q0
FN 27: TABWRITE 137/"PARAM" = Q0
FN 0: Q1627=3
FN 27: TABWRITE 103/"PARAM" = Q1627
CYCL DEF 9.0 DWELL TIME
CYCL DEF 9.1 DWELL 1
M9
M5
L M140 MB MAX
;ProgramFinish
FN 0: Q1628=2 ;STATUS_2
FN 27: TABWRITE 104/"PARAM" = Q1628
M30
LBL "GET_TIME"
FN 18: SYSREAD Q1677 = ID320 NR1 IDX1
Q1678 = INT Q1677
Q1679 = Q1678 % 86400
Q1680 = Q1679 % 3600
Q1681 = INT (Q1679 / 3600)
Q1682 = INT (Q1680 / 60)
Q1683 = INT (Q1680 % 60)
Q1677 = Q1681 *10000 + Q1682 * 100 + Q1683
Q1684 = INT Q1677
FN 20: WAIT FOR SYNC
LBL 0
LBL "ENDPROGRAM"
END PGM 1234 INCH
