BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-1.9685 Y-0.9843 Z-1.9685
BLK FORM 0.2 X+1.9685 Y+0.9843 Z+0.0394
;-------------------------------------
;T1 D=+2 CR=+0 - ZMIN=+0 - face mill
;T2 D=+0.375 CR=+0 - ZMIN=-0.3937 - flat end mill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - 2D-Face
TOOL CALL 1 Z S5000
;myToolComment
TOOL DEF 2
L M140 MB MAX
M3
FN 0: Q50=393.7 ;Cutting
FN 0: Q52=393.7 ;Finish
FN 0: Q57=196.85 ;Plunge
FN 0: Q59=393.7 ;Transition
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X+3.1496 Y-0.975 R0 FMAX
L Z+0.6299 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
L Z+0.2362 FMAX
L Z+0 FQ57
L X-3.1496 FQ52
CC X-3.1496 Y-0.4763
CP IPA-180 DR- FQ59
L X+3.1496 Y+0.0224 FQ52
L Z+0.6299 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - 2D-Contour
M5
M1
TOOL CALL 2 Z S5000
TOOL DEF 1
L M140 MB MAX
M3
FN 0: Q52=393.7 ;Finish
FN 0: Q53=393.7 ;Entry
FN 0: Q54=393.7 ;Exit
FN 0: Q58=196.85 ;Plunge
CALL LBL 1 ;DATUM
L X-0.375 Y+1.2151 R0 FMAX
L Z+0.6299 R0 FMAX
M8
L Z+0.2362 FMAX
L Z+0.0787 FQ58
L Z-0.3937
L Y+1.2111 FQ53
CC X-0.2175 Y+1.2111
CP IPA+90 DR+
L X+1.5354 Y+1.0536 FQ52
CC X+1.5354 Y+0.5512
CP IPA-90 DR-
L X+2.0379 Y-0.8661
CC X+1.8504 Y-0.8661
CP IPA-90 DR-
L X-1.6535 Y-1.0536
CC X-1.6535 Y-0.6693
CP IPA-90 DR-
L X-2.0379 Y+0.8661
CC X-1.8504 Y+0.8661
CP IPA-90 DR-
L X-0.2175 Y+1.0536
CC X-0.2175 Y+1.2111
CP IPA+90 DR+ FQ54
L X-0.06 Y+1.2151
L Z+0.6299 FMAX
;-------------------------------------
* - 2D-Contour with compensation left
FN 0: Q52=393.7 ;Finish
FN 0: Q53=393.7 ;Entry
FN 0: Q54=393.7 ;Exit
FN 0: Q58=196.85 ;Plunge
CALL LBL 1 ;DATUM
L X-0.4019 Y+1.1944 R0 FMAX
L Z+0.6299 R0 FMAX
L Z+0.2362 FMAX
L Z+0.0787 FQ58
L Z-0.3937
L X-0.6082 Y+1.1905 RL FQ53
CC X-0.2838 Y+1.1905
CP IPA+90 DR+
L X+1.5354 Y+0.8661 FQ52
CC X+1.5354 Y+0.5512
CP IPA-90 DR-
L X+1.8504 Y-0.8661
L X-1.6535
CC X-1.6535 Y-0.6693
CP IPA-90 DR-
L X-1.8504 Y+0.8661
L X-0.2838
CC X-0.2838 Y+1.1905
CP IPA+90 DR+ FQ54
L X-0.1657 Y+1.1944 R0
L Z+0.6299 FMAX
;-------------------------------------
* - 2D-Contour with compensation right
FN 0: Q52=393.7 ;Finish
FN 0: Q53=393.7 ;Entry
FN 0: Q54=393.7 ;Exit
FN 0: Q58=196.85 ;Plunge
CALL LBL 1 ;DATUM
L X-0.1657 Y+1.1944 R0 FMAX
L Z+0.6299 R0 FMAX
L Z+0.2362 FMAX
L Z+0.0787 FQ58
L Z-0.3937
L X+0.0405 Y+1.1905 RR FQ53
CC X-0.2838 Y+1.1905
CP IPA-90 DR-
L X-1.8504 Y+0.8661 FQ52
L Y-0.6693
CC X-1.6535 Y-0.6693
CP IPA+90 DR+
L X+1.8504 Y-0.8661
L Y+0.5512
CC X+1.5354 Y+0.5512
CP IPA+90 DR+
L X-0.2838 Y+0.8661
CC X-0.2838 Y+1.1905
CP IPA-90 DR- FQ54
L X-0.4019 Y+1.1944 R0
L Z+0.6299 FMAX
;-------------------------------------
* - 2D-Bore
FN 0: Q50=393.7 ;Cutting
FN 0: Q53=393.7 ;Entry
FN 0: Q54=393.7 ;Exit
CALL LBL 1 ;DATUM
L X+1.1951 Y-0.3525 R0 FMAX
L Z+0.6299 R0 FMAX
L Z+0.0787 FMAX
L Z+0.0375 FQ53
CC X+1.2326 Z+0.0375
CP IPA-90 DR-
L X+1.2514 Z+0
