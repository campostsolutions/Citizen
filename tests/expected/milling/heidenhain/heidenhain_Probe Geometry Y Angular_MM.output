BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-11 Y-11 Z-40
BLK FORM 0.2 X+491 Y+491 Z+51
;-------------------------------------
;T1 D=+5 CR=+2.5 - ZMIN=-5 - probe
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - Y Angle Probe Geometry
TOOL CALL 1 Z S50
L M140 MB MAX
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X+40 Y-12.5 R0 FMAX
L Z+206 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 420 MEASURE ANGLE ~
  Q263=+30 ;1ST POINT 1ST AXIS ~
  Q264=+0 ;1ST POINT 2ND AXIS ~
  Q265=+50 ;2ND POINT 1ST AXIS ~
  Q266=+0 ;2ND POINT 2ND AXIS ~
  Q272=+2 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q301=+1 ;MOVE TO CLEARANCE ~
  Q281=+1 ;MEASURING LOG
L Z+206 FMAX
CALL LBL 1 ;DATUM
FUNCTION FILECOPY "TCHPR420.TXT" TO "Y_Angle_Probe_Geometry"
FUNCTION FILEDELETE "TCHPR420.TXT"
M5
L M140 MB MAX
M30
END PGM 1234 MM
