BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-5.0394 Y-2.5394 Z-1.0394
BLK FORM 0.2 X+5.0394 Y+2.5394 Z+0
;-------------------------------------
;T1 D=+0.3937 CR=+0 TAPER=118deg - ZMIN=-1.1773 - center drill
;T3 D=+0.25 CR=+0 - ZMIN=-1.1181 - right hand tap
;T4 D=+0.375 CR=+0 TAPER=118deg - ZMIN=-1.2308 - drill
;T5 D=+0.375 CR=+0 - ZMIN=-1.1181 - right hand tap
;T6 D=+0.5 CR=+0 TAPER=118deg - ZMIN=-1.2683 - drill
;T7 D=+0.5 CR=+0 - ZMIN=-1.1181 - right hand tap
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - Center Drill
TOOL CALL 1 Z S5000
TOOL DEF 3
L M140 MB MAX
M3
L X+0.5 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.0787 ;DEPTH ~
  Q206=131.23 ;FEED RATE FOR PLUNGING ~
  Q202=+0.0787 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
CALL LBL 100
L X-4 Y-1.5 Z+0.5906 FMAX
;-------------------------------------
* - Drill
L X+0.5 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.1379 ;DEPTH ~
  Q206=131.23 ;FEED RATE FOR PLUNGING ~
  Q202=+1.1379 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
CALL LBL 100
L X-4 Y-1.5 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Tap
M5
M1
TOOL CALL 3 Z S7519
TOOL DEF 1
L M140 MB MAX
M3
L X+0.5 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.0787 ;DEPTH ~
  Q239=+0.05 ;THREAD PITCH ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE
CALL LBL 100
L X-4 Y-1.5 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Center Drill (2)
M5
M1
TOOL CALL 1 Z S5000
TOOL DEF 4
L M140 MB MAX
M3
L X+4 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.0787 ;DEPTH ~
  Q206=131.23 ;FEED RATE FOR PLUNGING ~
  Q202=+0.0787 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
CALL LBL 101
L X-3 Y+2 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Drill (2)
M5
M1
TOOL CALL 4 Z S3060
TOOL DEF 5
L M140 MB MAX
M3
L X+4 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.1914 ;DEPTH ~
  Q206=230 ;FEED RATE FOR PLUNGING ~
  Q202=+1.1914 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
CALL LBL 101
L X-3 Y+2 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Tap (2)
M5
M1
TOOL CALL 5 Z S5013
TOOL DEF 1
L M140 MB MAX
M3
L X+4 Y+2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.0787 ;DEPTH ~
  Q239=+0.0625 ;THREAD PITCH ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE
CALL LBL 101
L X-3 Y+2 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Center Drill (3)
M5
M1
TOOL CALL 1 Z S5000
TOOL DEF 6
L M140 MB MAX
M3
L X-1 Y-2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 200 DRILLING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.0787 ;DEPTH ~
  Q206=131.23 ;FEED RATE FOR PLUNGING ~
  Q202=+0.0787 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
CALL LBL 102
L X+3.5 Y-1.5 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Drill (3)
M5
M1
TOOL CALL 6 Z S2290
TOOL DEF 7
L M140 MB MAX
M3
L X-1 Y-2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 202 BORING ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.229 ;DEPTH ~
  Q206=230 ;FEED RATE FOR PLUNGING ~
  Q211=1 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
CALL LBL 102
L X+3.5 Y-1.5 Z+0.5906 FMAX
M9
L M140 MB MAX
;-------------------------------------
* - Tap (3)
M5
M1
TOOL CALL 7 Z S3760
TOOL DEF 1
L M140 MB MAX
M3
L X-1 Y-2 R0 FMAX
L Z+0.5906 R0 FMAX
M8
CYCL DEF 207 RIGID TAPPING NEW ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-1.0787 ;DEPTH ~
  Q239=+0.05 ;THREAD PITCH ~
  Q203=-0.0394 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE
CALL LBL 102
L X+3.5 Y-1.5 Z+0.5906 FMAX
M9
M5
L M140 MB MAX
M30

LBL 100 ;Center Drill
L FMAX M99
L X+1.5 Y+0.5 FMAX M99
L X+3 Y+1.5 FMAX M99
L X+1 Y-1.5 FMAX M99
L X-1 Y-0.5 FMAX M99
L X-2.5 Y+1 FMAX M99
L X-4.5 Y+2 FMAX M99
L X-4 Y-1.5 FMAX M99
LBL 0

LBL 101 ;Center Drill (2)
L FMAX M99
L X+4.5 Y-1 FMAX M99
L X+2.5 Y-2 FMAX M99
L X+2 Y-1 FMAX M99
L X+0 FMAX M99
L X-2.5 Y-0.5 FMAX M99
L X-4 Y+0 FMAX M99
L X-3 Y+2 FMAX M99
LBL 0

LBL 102 ;Center Drill (3)
L FMAX M99
L X-3 Y-1.5 FMAX M99
L X-4 Y+1 FMAX M99
L X-1.5 Y+0.5 FMAX M99
L X-1 Y+1.5 FMAX M99
L X+1.5 Y+2 FMAX M99
L X+4 Y+0.5 FMAX M99
L X+3.5 Y-1.5 FMAX M99
LBL 0

END PGM 1234 INCH
