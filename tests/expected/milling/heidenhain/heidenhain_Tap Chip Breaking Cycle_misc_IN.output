BEGIN PGM 1234 INCH
;mycomment
BLK FORM 0.1 Z X-1.9685 Y-0.9843 Z-1.9685
BLK FORM 0.2 X+1.9685 Y+0.9843 Z+0.0394
;-------------------------------------
;T4 D=+0.25 CR=+0 - ZMIN=-0.5512 - right hand tap
;-------------------------------------
L Z+0 R0 FMAX M92
;-------------------------------------
;Tap with chip breaking
TOOL CALL 4 Z S1000
L Z+0 R0 FMAX M92
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X+0.9843 Y+0.3937 R0 FMAX
L Z+0.6299 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 209 TAPPING W/ CHIP BRKG ~
  Q200=+0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.5512 ;DEPTH ~
  Q239=+0.05 ;THREAD PITCH ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+0.2362 ;2ND SET-UP CLEARANCE ~
  Q257=+0.1181 ;DEPTH FOR CHIP BRKNG ~
  Q256=+0.0197 ;DIST. FOR CHIP BRKNG ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L Z+0.6299 FMAX
M9
M5
L Z+0 R0 FMAX M92
M30
END PGM 1234 INCH
