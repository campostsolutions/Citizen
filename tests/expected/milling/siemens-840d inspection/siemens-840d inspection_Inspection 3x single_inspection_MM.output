; %_N_1234_MPF
; mycomment
; T1 D=6 CR=3 - ZMIN=22.5 - probe
DEF INT RETURNCODE
DEF STRING[128] RESULTSFILE
DEF STRING[128] OUTPUT
MSG("PROPERTY_COMMISSIONING_MODE_IS_ENABLED")
M0
; When the machine is measuring correctly please disable this property
MSG()
G54
G17 G710 G90 G94
G64
G0 SUPA Z0 D0

MSG ("3 Axis Inspection")
T1
M6
D1
; Renishaw OMP40-2 6mm x 50mm - Haas
SPOS=0
G17 G90 G94
G54
G0 X-20.5 Y-0.00004
G0 Z37.5
R1=_WP[3,0]/2
R8=3-R1
RESULTSFILE = "Setup1_milling_RESULTS"
OUTPUT = "START"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "DOCUMENTID f06057c0-1983-45ed-9e68-3abf8d573210"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "MODELVERSION c656480c-f2b5-4def-a1de-79a8ebf2a079"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "TOOLPATHID 19"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "G331 N1 A0 B0 C0 X0 Y0 Z-12.5"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = ";TOOLPATH 3 Axis Inspection"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "G330 N1 A0 B0 C0 X0 Y0 Z0 I0 R0"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "CALIBRATED RADIUS "<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "ECCENTRICITY X "<<ROUND(_WP[3,7]*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
OUTPUT = "ECCENTRICITY Y "<<ROUND(_WP[3,8]*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
IF R1 <= 0
MSG("PROBE NOT CALIBRATED OR PROPERTY CALIBRATED RADIUS INCORRECT")
M0
MSG()
ENDIF
IF R1 > 3
MSG("PROBE NOT CALIBRATED OR PROPERTY CALIBRATED RADIUS INCORRECT")
M0
MSG()
ENDIF
IF ABS(_WP[3,7]) > 0.2
MSG("PROBE NOT CALIBRATED OR PROPERTY ECCENTRICITY X INCORRECT")
M0
MSG()
ENDIF
IF ABS(_WP[3,8]) > 0.2
MSG("PROBE NOT CALIBRATED OR PROPERTY ECCENTRICITY Y INCORRECT")
M0
MSG()
ENDIF
M27
G4 F2
MSG("Ensure Probe Has Enabled")
M0
MSG()
G1 Z22.5 F3000
G17
R2=-20.5-_WP[3,7]
R3=-0.00004-_WP[3,8]
R4=-2.99987+R8
; Approach Move
MEAS=1 G1 X=R2 Y=R3 Z=R4 F1000
STOPRE
IF $A_PROBE[ABS(1)] ==1
MSG("PATH OBSTRUCTED")
M0
MSG()
ENDIF
; Measure Move
MSG("Probe is about to contact part. Move should stop on contact")
M0
MSG()
OUTPUT = "G800 N1 X-12.5 Y-0.00003 Z0.00008 I-1. J0. K0.00001 O0 U0.005 L-0.005"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=-10.5-_WP[3,7]
R3=-0.00002-_WP[3,8]
R4=-2.99993+R8
MEAS=1 G1 X=R2 Y=R3 Z=R4 F300
STOPRE
IF $A_PROBE[ABS(1)] <>1
MSG("NO POINT TAKEN")
M0
MSG()
ENDIF
R5=$AA_MW[X]+_WP[3,7]
R6=$AA_MW[Y]+_WP[3,8]
R7=$AA_MW[Z]+R1
OUTPUT = "G801 N1 X "<<ROUND(R5*10000)/10000 <<" Y"<<ROUND(R6*10000)/10000 <<" Z"<<ROUND(R7*10000)/10000 <<" R"<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
; calculate deviation
R9=(R5+((-1.*(-1))*R1))
R10=(R6+((0.*(-1))*R1))
R11=(R7+((0.00001*(-1))*R1))
R12=R9-(-12.5)
R13=R10-(-0.00003)
R14=(R11-(0.00008))
R15=SQRT((R12*R12)+(R13*R13)+(R14*R14))
R9=((-1.*R12)+(0.*R13)+(0.00001*R14))
IF (R9 <= 0)
R12=R15
ELSE
R12=(R15*(-1))
ENDIF
OUTPUT = "G802 N1 DEVIATION "<<ROUND(R12*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=-20.5-_WP[3,7]
R3=-0.00004-_WP[3,8]
R4=-2.99987+R8
; Retract Move
G1X=R2Y=R3Z=R4F3000
IF (R12 > 0.005)
MSG("Inspection point over tolerance")
M0
MSG()
ENDIF
IF (R12 < -0.005)
MSG("Inspection point under tolerance")
M0
MSG()
ENDIF
G1 X-20.5 Y-0.00004 Z22.5
G1 X-0.00002 Y-20.5
R2=-0.00002-_WP[3,7]
R3=-20.5-_WP[3,8]
R4=-2.99987+R8
; Approach Move
MEAS=1 G1 X=R2 Y=R3 Z=R4 F1000
STOPRE
IF $A_PROBE[ABS(1)] ==1
MSG("PATH OBSTRUCTED")
M0
MSG()
ENDIF
; Measure Move
OUTPUT = "G800 N2 X-0.00002 Y-12.5 Z0.00008 I0. J-1. K0.00001 O0 U0.005 L-0.005"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=-0.00001-_WP[3,7]
R3=-10.5-_WP[3,8]
R4=-2.99993+R8
MEAS=1 G1 X=R2 Y=R3 Z=R4 F300
STOPRE
IF $A_PROBE[ABS(1)] <>1
MSG("NO POINT TAKEN")
M0
MSG()
ENDIF
R5=$AA_MW[X]+_WP[3,7]
R6=$AA_MW[Y]+_WP[3,8]
R7=$AA_MW[Z]+R1
OUTPUT = "G801 N2 X "<<ROUND(R5*10000)/10000 <<" Y"<<ROUND(R6*10000)/10000 <<" Z"<<ROUND(R7*10000)/10000 <<" R"<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
; calculate deviation
R9=(R5+((0.*(-1))*R1))
R10=(R6+((-1.*(-1))*R1))
R11=(R7+((0.00001*(-1))*R1))
R12=R9-(-0.00002)
R13=R10-(-12.5)
R14=(R11-(0.00008))
R15=SQRT((R12*R12)+(R13*R13)+(R14*R14))
R9=((0.*R12)+(-1.*R13)+(0.00001*R14))
IF (R9 <= 0)
R12=R15
ELSE
R12=(R15*(-1))
ENDIF
OUTPUT = "G802 N2 DEVIATION "<<ROUND(R12*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=-0.00002-_WP[3,7]
R3=-20.5-_WP[3,8]
R4=-2.99987+R8
; Retract Move
G1X=R2Y=R3Z=R4F3000
IF (R12 > 0.005)
MSG("Inspection point over tolerance")
M0
MSG()
ENDIF
IF (R12 < -0.005)
MSG("Inspection point under tolerance")
M0
MSG()
ENDIF
G1 X-0.00002 Y-20.5 Z22.5
G1 X20.5 Y-0.0001
R2=20.5-_WP[3,7]
R3=-0.0001-_WP[3,8]
R4=-2.99973+R8
; Approach Move
MEAS=1 G1 X=R2 Y=R3 Z=R4 F1000
STOPRE
IF $A_PROBE[ABS(1)] ==1
MSG("PATH OBSTRUCTED")
M0
MSG()
ENDIF
; Measure Move
OUTPUT = "G800 N3 X12.5 Y-0.00006 Z0.00017 I1. J0. K0.00001 O0 U0.005 L-0.005"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=10.5-_WP[3,7]
R3=-0.00005-_WP[3,8]
R4=-2.99986+R8
MEAS=1 G1 X=R2 Y=R3 Z=R4 F300
STOPRE
IF $A_PROBE[ABS(1)] <>1
MSG("NO POINT TAKEN")
M0
MSG()
ENDIF
R5=$AA_MW[X]+_WP[3,7]
R6=$AA_MW[Y]+_WP[3,8]
R7=$AA_MW[Z]+R1
OUTPUT = "G801 N3 X "<<ROUND(R5*10000)/10000 <<" Y"<<ROUND(R6*10000)/10000 <<" Z"<<ROUND(R7*10000)/10000 <<" R"<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
; calculate deviation
R9=(R5+((1.*(-1))*R1))
R10=(R6+((0.*(-1))*R1))
R11=(R7+((0.00001*(-1))*R1))
R12=R9-(12.5)
R13=R10-(-0.00006)
R14=(R11-(0.00017))
R15=SQRT((R12*R12)+(R13*R13)+(R14*R14))
R9=((1.*R12)+(0.*R13)+(0.00001*R14))
IF (R9 <= 0)
R12=R15
ELSE
R12=(R15*(-1))
ENDIF
OUTPUT = "G802 N3 DEVIATION "<<ROUND(R12*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=20.5-_WP[3,7]
R3=-0.0001-_WP[3,8]
R4=-2.99973+R8
; Retract Move
G1X=R2Y=R3Z=R4F3000
IF (R12 > 0.005)
MSG("Inspection point over tolerance")
M0
MSG()
ENDIF
IF (R12 < -0.005)
MSG("Inspection point under tolerance")
M0
MSG()
ENDIF
G1 X20.5 Y-0.0001 Z22.5
G1 X0.00005 Y20.5
R2=0.00005-_WP[3,7]
R3=20.5-_WP[3,8]
R4=-3+R8
; Approach Move
MEAS=1 G1 X=R2 Y=R3 Z=R4 F1000
STOPRE
IF $A_PROBE[ABS(1)] ==1
MSG("PATH OBSTRUCTED")
M0
MSG()
ENDIF
; Measure Move
OUTPUT = "G800 N4 X0.00003 Y12.5 Z0 I0. J1. K0. O0 U0.005 L-0.005"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=0.00002-_WP[3,7]
R3=10.5-_WP[3,8]
R4=-3+R8
MEAS=1 G1 X=R2 Y=R3 Z=R4 F300
STOPRE
IF $A_PROBE[ABS(1)] <>1
MSG("NO POINT TAKEN")
M0
MSG()
ENDIF
R5=$AA_MW[X]+_WP[3,7]
R6=$AA_MW[Y]+_WP[3,8]
R7=$AA_MW[Z]+R1
OUTPUT = "G801 N4 X "<<ROUND(R5*10000)/10000 <<" Y"<<ROUND(R6*10000)/10000 <<" Z"<<ROUND(R7*10000)/10000 <<" R"<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
; calculate deviation
R9=(R5+((0.*(-1))*R1))
R10=(R6+((1.*(-1))*R1))
R11=(R7+((0.*(-1))*R1))
R12=R9-(0.00003)
R13=R10-(12.5)
R14=(R11-(0))
R15=SQRT((R12*R12)+(R13*R13)+(R14*R14))
R9=((0.*R12)+(1.*R13)+(0.*R14))
IF (R9 <= 0)
R12=R15
ELSE
R12=(R15*(-1))
ENDIF
OUTPUT = "G802 N4 DEVIATION "<<ROUND(R12*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=0.00005-_WP[3,7]
R3=20.5-_WP[3,8]
R4=-3+R8
; Retract Move
G1X=R2Y=R3Z=R4F3000
IF (R12 > 0.005)
MSG("Inspection point over tolerance")
M0
MSG()
ENDIF
IF (R12 < -0.005)
MSG("Inspection point under tolerance")
M0
MSG()
ENDIF
G1 X0.00005 Y20.5 Z22.5
G1 X0.00016 Y0.00012
R2=0.00016-_WP[3,7]
R3=0.00012-_WP[3,8]
R4=17.5+R8
; Approach Move
MEAS=1 G1 X=R2 Y=R3 Z=R4 F1000
STOPRE
IF $A_PROBE[ABS(1)] ==1
MSG("PATH OBSTRUCTED")
M0
MSG()
ENDIF
; Measure Move
OUTPUT = "G800 N5 X0.0001 Y0.00007 Z12.5 I0.00001 J0.00001 K1. O0 U0.005 L-0.005"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=0.00008-_WP[3,7]
R3=0.00006-_WP[3,8]
R4=7.5+R8
MEAS=1 G1 X=R2 Y=R3 Z=R4 F300
STOPRE
IF $A_PROBE[ABS(1)] <>1
MSG("NO POINT TAKEN")
M0
MSG()
ENDIF
R5=$AA_MW[X]+_WP[3,7]
R6=$AA_MW[Y]+_WP[3,8]
R7=$AA_MW[Z]+R1
OUTPUT = "G801 N5 X "<<ROUND(R5*10000)/10000 <<" Y"<<ROUND(R6*10000)/10000 <<" Z"<<ROUND(R7*10000)/10000 <<" R"<<ROUND(R1*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
; calculate deviation
R9=(R5+((0.00001*(-1))*R1))
R10=(R6+((0.00001*(-1))*R1))
R11=(R7+((1.*(-1))*R1))
R12=R9-(0.0001)
R13=R10-(0.00007)
R14=(R11-(12.5))
R15=SQRT((R12*R12)+(R13*R13)+(R14*R14))
R9=((0.00001*R12)+(0.00001*R13)+(1.*R14))
IF (R9 <= 0)
R12=R15
ELSE
R12=(R15*(-1))
ENDIF
OUTPUT = "G802 N5 DEVIATION "<<ROUND(R12*10000)/10000
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
R2=0.00016-_WP[3,7]
R3=0.00012-_WP[3,8]
R4=17.5+R8
; Retract Move
G1X=R2Y=R3Z=R4F3000
IF (R12 > 0.005)
MSG("Inspection point over tolerance")
M0
MSG()
ENDIF
IF (R12 < -0.005)
MSG("Inspection point under tolerance")
M0
MSG()
ENDIF
G1 X0.00016 Y0.00012 Z22.5
G1 Z37.5
M28
G4 F2
MSG("Ensure Probe Has Disabled")
M0
MSG()
OUTPUT = "END"
WRITE(RETURNCODE, RESULTSFILE, OUTPUT)
MSG("Results file should now be located in The nc program folder")
M0
MSG()
M0

M5
G0 SUPA Z0 D0
D1
M30
