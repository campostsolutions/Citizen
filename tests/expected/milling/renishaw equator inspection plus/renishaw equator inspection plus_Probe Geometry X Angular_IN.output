$$ X ANGLE PROBE GEOMETRY
$$ =============================================================================
CALL/EXTERN,DMIS,M(Turn_probe_on_9832),,SCANNING
CALL/EXTERN,DMIS,M(Recall_WCS),G54
WKPLAN/XYPLAN
CALL/EXTERN,DMIS,M(Protected_position_9810),-0.4921,1.5748,8.1102
CALL/EXTERN,DMIS,M(Protected_position_9810),-0.4921,1.5748,2.2047
CALL/EXTERN,DMIS,M(Protected_position_9810),-0.4921,1.5748,-0.1969
CALL/EXTERN,DMIS,M(Line_measurement_9843),X,0.,0.7874,0,1,0,0.3937,B1.W2.0
GOTO/ZAXIS,2.3031
CALL/EXTERN,DMIS,M(Protected_position_9810),-0.4921,1.5748,8.1102

CALL/EXTERN,DMIS,M(Turn_probe_off_9833)

CALL/EXTERN,DMIS,M(Retract_to_clearance),Z
CALL/EXTERN,DMIS,M(Retract_to_clearance),XY
