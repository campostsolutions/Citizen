//  --- INFO ---
// MYCOMMENT
//  --- INIT ---
TCorrOff                          // Deactivate RTCP function
RMO                               // Reset the rotary axis coordinates

Set_Offset_R -od -tor             // change calculation rule for 2D radius correction

PROTOCOL -start -head
MDC -Start -User1="Hauptprogramm"

//  --- BEGIN MACHINING ---
MaCoor -all                       // Reset all coordinate shifts
LoadZero="1"-h=0.0               // Example: Workpiece zero point from zero point memory

//  --- DYNAMIC ---
Cam_Undersize=0                   // Workpiece undersize (minimum oversize of all programs)
DynAuto="General"                 // ADPA rule"General"

//  --- OPTIONS ---
// SET_WARMUP=120                 // MANUAL USER SPINDLE WARMUP
// SET_OFFSET_R=0.00              // MANUAL USER OFFSET FOR 2D_COMPENSATION

// TOOLS
// -------------------------------------
//   T2 D=0.375 - FLAT END MILL
//   T8 D=0.5 - FLAT END MILL
// -------------------------------------

//  --- BEGIN MACHINING ---
// 2D-FACE FRONT

// --------------------------------------------------------------------------------------------------
//  T2, TT=MYTOOL2, TOOLDATA DIA=0.375, TIPR=0
// --------------------------------------------------------------------------------------------------
T2
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP -ssa                           // Approach safety position as starting position
WaitC                             // Option: Program pause, if it was activated

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on

// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A30
G00 X2.1253 Y-0.7107
G00 Z1.1168
CALL LBL1
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D-FACE LEFT

// --------------------------------------------------------------------------------------------------
//  T8, TT=MYTOOL8, TOOLDATA DIA=0.5, TIPR=0
// --------------------------------------------------------------------------------------------------
T8
S6000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on

// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=-90 // Zero point offset for rotary axis machines (no traversing movement)
G01 C-90 F393
G01 A30
G00 X1.2522 Y-1.5631
G00 Z1.6089
CALL LBL2
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D-FACE LEFT TOOLCHANGE

// --------------------------------------------------------------------------------------------------
//  T2, TT=MYTOOL2, TOOLDATA DIA=0.375, TIPR=0
// --------------------------------------------------------------------------------------------------
T2
S5000 M3
WarmUp                            // Warm-up (according to default or TT)

// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

VacAutoOff                        // Automatic graphite vacuum cleaner off
EmuOn -out                        // Emulsion on
HazeVacOn                         // Option: Mist suctioning on

// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=-90 // Zero point offset for rotary axis machines (no traversing movement)
G01 C-90 F393
G01 A30
G00 X1.2397 Y-1.5631
G00 Z1.6089
CALL LBL3
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D-FACE BACK
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position


// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=-180 // Zero point offset for rotary axis machines (no traversing movement)
G01 C-180 F393
G01 A30
G00 X2.2816 Y-0.7107
G00 Z1.1168
CALL LBL4
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D-FACE BACK DUPLICATE
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position


// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=-180 // Zero point offset for rotary axis machines (no traversing movement)
G01 C-180 F393
G01 A30
G00 X2.2816 Y-0.7107
G00 Z1.1168
CALL LBL5
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D CONTOUR TOP
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position

G00 X0.041 Y-0.0375
G00 Z0.6394
CALL LBL6

// 2D-FACE RIGHT
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position


// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=30 ;C=90 // Zero point offset for rotary axis machines (no traversing movement)
G01 C90 F393
G01 A30
G00 X1.2051 Y-1.5631
G00 Z1.6089
CALL LBL7
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0

// 2D-FACE DIAGONAL
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
Cam_Stock=0                       // CAM oversize
SP                                // Safety position


// START_3PLUS_2AXIS
// POSITIONING OF THE ROTARY AXES, CARRYING ALONG THE ZERO POINT
ROTZERO= A=22.208 ;C=45 // Zero point offset for rotary axis machines (no traversing movement)
G01 C45 F393
G01 A22.208
G00 X0.6947 Y-1.2538
G00 Z1.4162
CALL LBL8
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off
SP                                // Safety position

ROTZERO= A=0 ;C=0 // Zero point offset for rotary axis machines (no traversing movement)
G01 C0 F393
G01 A0


//  RESET_WARMUP                  // RESETTING A TEMPORARY WARM-UP TIME
//  RESET_OFFSET_R                // INITIALIZE 2D-RADIUS CORRECTION OFFSET
//  LINEUP = 0


//  --- END OF MACHINING ---


MDC -End
 M30
