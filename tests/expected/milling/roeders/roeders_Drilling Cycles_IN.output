  Q204=0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
G00 M99
G00 X0.9843 M99
G00 Z0.6299

// CHIP BREAKING
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

G00 X-0.9843 Y0.3937
G00 Z0.6299
CYCL DEF 203 UNIVERSAL DRILLING ~
  Q200=0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.651 ;DEPTH ~
  Q206=15.75 ;FEED RATE FOR PLUNGING ~
  Q202=0.0394 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=0 ;SURFACE COORDINATE ~
  Q204=0.2362 ;2ND SET-UP CLEARANCE ~
  Q212=0.0039 ;DECREMENT ~
  Q213=5 ;BREAKS ~
  Q205=0.0197 ;MIN. PLUNGING DEPTH ~
  Q211=0 ;DWELL TIME AT DEPTH ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q256=0.004 ;DIST. FOR CHIP BRKNG
G00 M99
G00 X0.9843 M99
G00 Z0.6299

// DEEP DRILLING
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

G00 X-0.9843 Y0.3937
G00 Z0.6299
CYCL DEF 200 DRILLING ~
  Q200=0.1969 ;SET-UP CLEARANCE ~
  Q201=-0.651 ;DEPTH ~
  Q206=15.75 ;FEED RATE FOR PLUNGING ~
  Q202=0.0394 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=0 ;SURFACE COORDINATE ~
  Q204=0.2362 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
G00 M99
G00 X0.9843 M99
G00 Z0.6299

// BREAK-THROUGH DRILLING
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

G00 X-0.9843 Y0.3937
G00 Z0.6299
G00 Z0.2362
G00 Z0.1969
G01 Z-0.4498 F15.75
S3000
G01 Z-0.651 F19.69
S5000
G01 Z0.1969 F39.37
G00 Z0.2362
G00 X0.9843
G00 Z0.1969
G01 Z-0.4498 F15.75
S3000
G01 Z-0.651 F19.69
S5000
G01 Z0.1969 F39.37
G00 Z0.2362
G00 Z0.6299

// GUIDED DEEP DRILLING
// DYNAMIC
Cam_Tol=0.0004                      // CAM tolerance
SP                                // Safety position

G00 X-0.9843 Y0.3937
G00 Z0.6299
CYCL DEF 241 SINGLE-FLUTED DEEP-HOLE DRILLING ~
 Q200=0.1969 ;SET-UP CLEARANCE ~
 Q201=-0.651 ;DEPTH ~
 Q206=15.75 ;FEED RATE FOR PLUNGING ~
 Q211=0 ;DWELL TIME AT DEPTH ~
 Q203=0 ;SURFACE COORDINATE ~
 Q204=0.2362 ;2ND SET-UP CLEARANCE ~
 Q379=0.2012 ;STARTING POINT ~
 Q253=19.69 ;F PRE-POSITIONING ~
 Q208=39.37 ;RETRACT FEED RATE ~
 Q426=3 ;DIR. OF SPINDLE ROT. ~
 Q427=3000 ;ENTRY EXIT SPEED ~
 Q428=5000 ;DRILLING SPEED ~
 Q429=VacAutoOff                        // Automatic graphite vacuum cleaner off,EmuOn -out                        // Emulsion on,HazeVacOn                         // Option: Mist suctioning on ;COOLANT ON ~
 Q430=EmuOff                            // Emulsion off,HazeVacOff                        // Option: Mist suctioning off ;COOLANT OFF ~
 Q435=0 ;DWELL DEPTH
G00 M99
G00 X0.9843 M99
G00 Z0.6299
EmuOff                            // Emulsion off
HazeVacOff                        // Option: Mist suctioning off

