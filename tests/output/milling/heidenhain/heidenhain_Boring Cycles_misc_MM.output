BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-50 Y-25 Z-50
BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-15 - drill
;-------------------------------------
L Z+0 R0 FMAX M92
;-------------------------------------
;Stop Boring
TOOL CALL 3 Z S5000
L Z+0 R0 FMAX M92
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=0 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
;-------------------------------------
;Fine Boring
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 202 BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-15 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
;-------------------------------------
;Back Boring
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 204 BACK BORING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q249=+0.2 ;DEPTH REDUCTION ~
  Q250=+15 ;MATERIAL THICKNESS ~
  Q251=+0.01 ;OFF-CENTER DISTANCE ~
  Q252=+0 ;TOOL EDGE HEIGHT ~
  Q253=MAX ;F PRE-POSITIONING ~
  Q254=400 ;F COUNTERBORING ~
  Q255=0 ;DWELL AT BOTTOM ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q214=1 ;DISENGAGING DIRECTION ~
  Q336=0 ;ANGLE OF SPINDLE
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
M9
M5
L Z+0 R0 FMAX M92
M30
END PGM 1234 MM
