BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;T2 D=+9.525 CR=+0 - ZMIN=-5 - flat end mill
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-16.535 - drill
;T4 D=+6.35 CR=+0 - ZMIN=-14 - right hand tap
;T5 D=+6.35 CR=+0 - ZMIN=-14 - left hand tap
;T6 D=+5.08 CR=+0 - ZMIN=-14 - reamer
;T7 D=+6.35 CR=+0 TAPER=90deg - ZMIN=-0.2 - spot drill
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
