BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-11 Y-11 Z-40
BLK FORM 0.2 X+491 Y+491 Z+51
;-------------------------------------
;"MYPROBE1" D=+5 CR=+2.5 - ZMIN=-25 - probe
;-------------------------------------
TOOL CALL Z ;SET TOOL AXIS FOR M140
L M140 MB MAX
;-------------------------------------
* - X Probe Geometry (2)
TOOL CALL "MYPROBE1" Z S50
L M140 MB MAX
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-12.6 Y+40 R0 FMAX
L Z+206 R0 FMAX
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
TCH PROBE 427 MEASURE COORDINATE ~
  Q263=-0.1 ;1ST POINT 1ST AXIS ~
  Q264=+40 ;1ST POINT 2ND AXIS ~
  Q261=-2.5 ;MEASURING HEIGHT ~
  Q320=+10 ;SET-UP CLEARANCE ~
  Q272=+1 ;MEASURING AXIS ~
  Q267=+1 ;TRAVERSE DIRECTION ~
  Q260=+56 ;CLEARANCE HEIGHT ~
  Q281=+1 ;MEASURING LOG ~
  Q288=+0.9 ;MAXIMUM DIMENSION ~
  Q289=-1.1 ;MINIMUM DIMENSION ~
  Q309=+1 ;PGM-STOP IF ERROR ~
  Q330=+0 ;TOOL
L Z+206 FMAX
CALL LBL 1 ;DATUM
