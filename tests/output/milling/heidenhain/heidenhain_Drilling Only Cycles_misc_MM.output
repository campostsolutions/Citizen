BEGIN PGM 1234 MM
;mycomment
BLK FORM 0.1 Z X-50 Y-25 Z-50
BLK FORM 0.2 X+50 Y+25 Z+1
;-------------------------------------
;T3 D=+5.11 CR=+0 TAPER=118deg - ZMIN=-16.535 - drill
;-------------------------------------
L Z+0 R0 FMAX M92
;-------------------------------------
;Rapid out (3)
TOOL CALL 3 Z S5000
L Z+0 R0 FMAX M92
M3
LBL 1
CYCL DEF 247 DATUM SETTING ~
  Q339=1 ; DATUM NUMBER
LBL 0
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
M8
CYCL DEF 32.0 TOLERANCE
CYCL DEF 32.1
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+16.535 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
;-------------------------------------
;Chip breaking (3)
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 203 UNIVERSAL DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q212=+0.1 ;DECREMENT ~
  Q213=5 ;BREAKS ~
  Q205=+0.5 ;MIN. PLUNGING DEPTH ~
  Q211=0 ;DWELL AT BOTTOM ~
  Q208=MAX ;RETRACTION FEED RATE ~
  Q256=+0.102 ;DIST. FOR CHIP BRKNG
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
;-------------------------------------
;Deep drilling (3)
CALL LBL 1 ;DATUM
L X-25 Y+10 R0 FMAX
L Z+16 R0 FMAX
CYCL DEF 200 DRILLING ~
  Q200=+5 ;SET-UP CLEARANCE ~
  Q201=-16.535 ;DEPTH ~
  Q206=400 ;FEED RATE FOR PLUNGING ~
  Q202=+1 ;INFEED DEPTH ~
  Q210=0 ;DWELL AT TOP ~
  Q203=+0 ;SURFACE COORDINATE ~
  Q204=+6 ;2ND SET-UP CLEARANCE ~
  Q211=0 ;DWELL AT BOTTOM
L FMAX M99
L X+25 FMAX M99
L Z+16 FMAX
M9
M5
L Z+0 R0 FMAX M92
M30
END PGM 1234 MM
